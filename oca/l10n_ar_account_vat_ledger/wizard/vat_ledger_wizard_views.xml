<odoo>
  <record id="view_vat_ledger_wizard" model="ir.ui.view">
    <field name="name">vat.ledger.wizard.form</field>
    <field name="model">vat.ledger.wizard</field>
    <field name="arch" type="xml">
      <form string="Exportar Libro IVA Digital (TXT)">
        <group>
          <field name="company_id"/>
          <field name="book_type"/>
          <field name="date_from"/>
          <field name="date_to"/>
        </group>
        <footer>
          <button name="action_export" type="object" class="btn-primary" string="Exportar TXT"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_vat_ledger_wizard" model="ir.actions.act_window">
    <field name="name">Exportar Libro IVA Digital</field>
    <field name="res_model">vat.ledger.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
