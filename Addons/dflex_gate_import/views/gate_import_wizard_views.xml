<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_gate_import_wizard_form" model="ir.ui.view">
    <field name="name">x.gate.import.wizard.form</field>
    <field name="model">x.gate.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importar Portones desde Excel">
        <group>
          <field name="file_name"/>
          <field name="file_data" filename="file_name"/>
          <field name="sheet_name"/>
          <field name="header_row"/>
          <field name="data_start_row"/>
          <field name="create_batch"/>
        </group>
        <footer>
          <button string="Importar" type="object" name="action_import" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_open_gate_import_wizard" model="ir.actions.act_window">
    <field name="name">Importar Excel</field>
    <field name="res_model">x.gate.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
