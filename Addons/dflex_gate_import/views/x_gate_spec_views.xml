<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_x_gate_spec_tree" model="ir.ui.view">
    <field name="name">x.gate.spec.tree</field>
    <field name="model">x.gate.spec</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="import_batch_id"/>
      </list>
    </field>
  </record>

  <record id="view_x_gate_spec_form" model="ir.ui.view">
    <field name="name">x.gate.spec.form</field>
    <field name="model">x.gate.spec</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="import_batch_id"/>
          </group>
          <notebook>
            <page string="Datos (tabla)">
              <field name="preview_html" nolabel="1"/>
            </page>
            <page string="JSON">
              <field name="data_json" widget="json"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_x_gate_spec_tree" model="ir.actions.act_window">
    <field name="name">Portones (Fichas)</field>
    <field name="res_model">x.gate.spec</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
