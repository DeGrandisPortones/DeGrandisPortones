<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_x_gate_import_batch_tree" model="ir.ui.view">
    <field name="name">x.gate.import.batch.tree</field>
    <field name="model">x.gate.import.batch</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="file_name"/>
        <field name="sheet_name"/>
        <field name="row_count"/>
      </tree>
    </field>
  </record>

  <record id="view_x_gate_import_batch_form" model="ir.ui.view">
    <field name="name">x.gate.import.batch.form</field>
    <field name="model">x.gate.import.batch</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name"/>
            <field name="file_name"/>
            <field name="sheet_name"/>
            <field name="row_count"/>
          </group>
          <group string="Archivo">
            <field name="file_data" filename="file_name"/>
          </group>
          <notebook>
            <page string="Fichas creadas">
              <field name="gate_spec_ids">
                <tree>
                  <field name="name"/>
                </tree>
              </field>
            </page>
            <page string="Notas">
              <field name="note"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_x_gate_import_batch_tree" model="ir.actions.act_window">
    <field name="name">Importaciones</field>
    <field name="res_model">x.gate.import.batch</field>
    <field name="view_mode">tree,form</field>
  </record>
</odoo>
