<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Root menu under Manufacturing -->
  <menuitem id="menu_dflex_root"
            name="Portones"
            parent="mrp.menu_mrp_root"
            action="action_x_gate_spec_tree"
            sequence="80"/>
  <!-- Submenus -->
  <menuitem id="menu_dflex_gate"
            name="Portones (Fichas)"
            parent="menu_dflex_root"
            action="action_x_gate_spec_tree"
            sequence="10"/>
  <menuitem id="menu_dflex_import"
            name="Importar Excel"
            parent="menu_dflex_root"
            action="action_open_gate_import_wizard"
            sequence="20"/>
  <menuitem id="menu_dflex_batches"
            name="Importaciones"
            parent="menu_dflex_root"
            action="action_x_gate_import_batch_tree"
            sequence="30"/>

  <!-- Force-clear any lingering group restrictions from previous installs -->
  <record id="menu_dflex_root" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [])]"/>
  </record>
  <record id="menu_dflex_gate" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [])]"/>
  </record>
  <record id="menu_dflex_import" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [])]"/>
  </record>
  <record id="menu_dflex_batches" model="ir.ui.menu">
    <field name="groups_id" eval="[(6, 0, [])]"/>
  </record>
</odoo>
