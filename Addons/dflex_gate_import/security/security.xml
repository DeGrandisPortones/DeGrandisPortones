<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Security group only for De Grandis Portones users -->
<!-- Record rules: only records of the current company -->
  <record id="rule_x_gate_spec_company" model="ir.rule">
    <field name="name">x.gate.spec multicompany</field>
    <field name="model_id" ref="model_x_gate_spec"/>
    <field name="domain_force">[('company_id','=',user.company_id.id)]</field>
</record>

  <record id="rule_x_gate_import_batch_company" model="ir.rule">
    <field name="name">x.gate.import.batch multicompany</field>
    <field name="model_id" ref="model_x_gate_import_batch"/>
    <field name="domain_force">[('company_id','=',user.company_id.id)]</field>
</record>
</odoo>
