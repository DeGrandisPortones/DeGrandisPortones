<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_official_aux_validation_confirm_wizard_form" model="ir.ui.view">
        <field name="name">official.aux.validation.confirm.wizard.form</field>
        <field name="model">official.aux.validation.confirm.wizard</field>
        <field name="arch" type="xml">
            <form string="Incongruencia contable">
                <sheet>
                    <group>
                        <field name="move_ids" invisible="1"/>
                        <field name="message" nolabel="1" readonly="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button string="No, cancelar" special="cancel" class="btn-secondary"/>
                    <button string="Sí, continuar" type="object" name="action_continue" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
