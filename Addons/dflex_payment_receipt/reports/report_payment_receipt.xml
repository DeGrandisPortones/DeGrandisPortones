
<odoo>
  <template id="dflex_report_payment_receipt_document" inherit_id="account.report_payment_receipt_document">
    <xpath expr="//t[@t-call='web.external_layout' or @t-call='web.external_layout_clean']" position="replace">
      <t t-call="web.external_layout">
        <t t-set="o" t-value="o"/>
        
        <t t-set="has_payment_reference" t-value="'payment_reference' in o._fields and o.payment_reference"/>
        <t t-set="obs" t-value="(('narration' in o._fields and o.narration) or ('communication' in o._fields and o.communication) or (has_payment_reference and o.payment_reference) or '')"/>
        <t t-set="is_bank" t-value="o.journal_id and o.journal_id.type == 'bank'"/>
        <t t-set="is_cash" t-value="o.journal_id and o.journal_id.type == 'cash'"/>
        <t t-set="jn" t-value="(o.journal_id.name or '').lower() if o.journal_id else ''"/>
        <t t-set="is_getnet" t-value="'getnet' in jn"/>
        <t t-set="is_mp" t-value="'mercadopago' in jn or 'mercado' in jn"/>
        <t t-set="is_checks_journal" t-value="'cheque' in jn or 'checks' in jn or 'terceros' in jn"/>
        <!-- LATAM/ADHOC CHEQUE FIELDS (EXPLICIT) -->
        <t t-set="check_lines"
           t-value="
             (('l10n_latam_new_check_ids' in o._fields and o.l10n_latam_new_check_ids) and o.l10n_latam_new_check_ids) or
             (('l10n_latam_move_check_ids' in o._fields and o.l10n_latam_move_check_ids) and o.l10n_latam_move_check_ids) or
             (('third_party_check_ids' in o._fields and o.third_party_check_ids) and o.third_party_check_ids) or
             (('received_check_ids' in o._fields and o.received_check_ids) and o.received_check_ids) or
             (('check_ids' in o._fields and o.check_ids) and o.check_ids) or
             (('check_line_ids' in o._fields and o.check_line_ids) and o.check_line_ids) or
             False
           "/>
        <t t-set="has_checks" t-value="bool(check_lines)"/>
        <t t-set="acc_num" t-value="(o.journal_id.bank_account_id.acc_number if (o.journal_id and o.journal_id.bank_account_id) else '')"/>
        <t t-set="acc_mask" t-value="('••••' + str(acc_num)[-4:]) if acc_num else ''"/>

        <style>
          .r-wrap { padding: 2px 0; }
          .r-header { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
          .r-title { font-size:20px; font-weight:700; letter-spacing:.5px; }
          .r-muted { color:#6b7280; }
          .r-small { font-size:11px; }
          .r-kv td { padding:2px 6px; vertical-align:top; }
          .r-section { margin-top:14px; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden; }
          .r-section > .head { background:#f3f4f6; font-weight:600; padding:8px 10px; border-bottom:1px solid #e5e7eb; }
          .r-section table { width:100%; border-collapse:collapse; }
          .r-section th, .r-section td { padding:8px 10px; border-bottom:1px solid #e5e7eb; }
          .r-right { text-align:right; }
          .r-pre { white-space:pre-line; }
          .r-total { font-size:14px; font-weight:700; }
          .r-foot { margin-top:18px; display:flex; gap:16px; }
          .r-foot .sig { flex:1; text-align:center; }
          .r-foot .sig .line { border-top:1px solid #9ca3af; margin:20px 20px 6px; }
          .r-mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace; }
        </style>

        <div class="page r-wrap">
          <div class="r-header">
            <div>
              <div class="r-title">ORDEN DE COBRANZA</div>
              <table class="r-kv r-small">
                <tr><td class="r-muted">N°</td><td class="r-mono"><t t-esc="o.name"/></td></tr>
                <tr><td class="r-muted">Cliente</td><td><t t-esc="o.partner_id.display_name"/></td></tr>
                <tr><td class="r-muted">Fecha</td><td><t t-esc="(o.date or o.create_date).strftime('%d/%m/%Y') if (o.date or o.create_date) else ''"/></td></tr>
              </table>
            </div>
            <div>
              <table class="r-kv r-small">
                <tr><td class="r-muted">CUIT</td><td><t t-esc="o.partner_id.vat or ''"/></td></tr>
                <tr t-if="'l10n_ar_afip_responsibility_type_id' in o.partner_id._fields and o.partner_id.l10n_ar_afip_responsibility_type_id">
                  <td class="r-muted">Sit. IVA</td>
                  <td><t t-esc="o.partner_id.l10n_ar_afip_responsibility_type_id.name"/></td>
                </tr>
                <tr><td class="r-muted">Domicilio</td><td><t t-esc="o.partner_id.contact_address or ''"/></td></tr>
                <tr><td class="r-muted">Teléfonos</td>
                  <td>
                    <t t-if="o.partner_id.phone"><t t-esc="o.partner_id.phone"/></t>
                    <t t-if="o.partner_id.mobile"> / <t t-esc="o.partner_id.mobile"/></t>
                  </td>
                </tr>
              </table>
            </div>
          </div>

          <div class="r-section">
            <div class="head">MEDIOS DE PAGO</div>
            <table>
              <thead>
                <tr>
                  <th>Detalle</th>
                  <th class="r-right">Importe</th>
                </tr>
              </thead>
              <tbody>
                <!-- Detalle de cheques (Latam/ADHOC) -->
                <t t-if="has_checks">
                  <tr>
                    <td colspan="2" style="padding:0;">
                      <table style="width:100%; border-collapse:collapse;">
                        <thead>
                          <tr>
                            <th style="padding:6px 10px;">Número</th>
                            <th style="padding:6px 10px;">Banco</th>
                            <th style="padding:6px 10px;">CUIT del emisor</th>
                            <th style="padding:6px 10px;">Razón social</th>
                            <th style="padding:6px 10px;">Vencimiento</th>
                            <th class="r-right" style="padding:6px 10px;">Importe</th>
                          </tr>
                        </thead>
                        <tbody>
                          <tr t-foreach="check_lines" t-as="c">
                            <td>
                              <t t-esc="('number' in c._fields and c.number) or ('name' in c._fields and c.name) or c.display_name"/>
                            </td>
                            <td>
                              <t t-esc="(c.bank_id and c.bank_id.name) if 'bank_id' in c._fields else ''"/>
                            </td>
                            <td>
                              <t t-esc="('owner_vat' in c._fields and c.owner_vat) or ('owner_cuit' in c._fields and c.owner_cuit) or ''"/>
                            </td>
                            <td>
                              <t t-esc="('owner_name' in c._fields and c.owner_name) or ''"/>
                            </td>
                            <td>
                              <t t-if="('payment_date' in c._fields and c.payment_date)"><t t-esc="c.payment_date.strftime('%d/%m/%Y')"/></t>
                              <t t-elif="('due_date' in c._fields and c.due_date)"><t t-esc="c.due_date.strftime('%d/%m/%Y')"/></t>
                              <t t-elif="('issue_date' in c._fields and c.issue_date)"><t t-esc="c.issue_date.strftime('%d/%m/%Y')"/></t>
                            </td>
                            <td class="r-right">
                              <span t-esc="('amount' in c._fields and c.amount) or ('payment_amount' in c._fields and c.payment_amount) or 0.0"
                                    t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                            </td>
                          </tr>
                        </tbody>
                      </table>
                    </td>
                  </tr>
                </t>

                <!-- Resto de medios (cuando no hay check_lines) -->
                <t t-if="(not has_checks) and is_checks_journal">
                  <tr>
                    <td>Cheques de terceros</td>
                    <td class="r-right"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                  </tr>
                </t>

                <t t-if="(not has_checks) and (not is_checks_journal) and is_getnet">
                  <tr>
                    <td>Pago hecho por <b>tarjeta de crédito</b> plataforma <b>Getnet</b></td>
                    <td class="r-right"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                  </tr>
                </t>

                <t t-if="(not has_checks) and (not is_checks_journal) and (not is_getnet) and is_mp">
                  <tr>
                    <td>Pago hecho por <b>tarjeta / Link de pago</b> a <b>Mercadopago</b></td>
                    <td class="r-right"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                  </tr>
                </t>

                <t t-if="(not has_checks) and (not is_checks_journal) and (not is_getnet) and (not is_mp) and is_bank">
                  <tr>
                    <td>
                      <t>Transferencia bancaria a </t>
                      <t t-esc="o.journal_id.bank_id and o.journal_id.bank_id.name or 'Banco'"/>
                      <t t-if="acc_mask"> cuenta <t t-esc="acc_mask"/></t>
                      <t t-if="has_payment_reference"> — N° <t t-esc="o.payment_reference"/></t>
                    </td>
                    <td class="r-right"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                  </tr>
                </t>

                <t t-if="(not has_checks) and (not is_checks_journal) and (not is_getnet) and (not is_mp) and (not is_bank) and is_cash">
                  <tr>
                    <td>Pago en efectivo</td>
                    <td class="r-right"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                  </tr>
                </t>

                <t t-if="(not has_checks) and (not is_checks_journal) and (not is_getnet) and (not is_mp) and (not is_bank) and (not is_cash)">
                  <tr>
                    <td><t t-esc="(o.payment_method_line_id and o.payment_method_line_id.name) or 'Pago'"/></td>
                    <td class="r-right"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></td>
                  </tr>
                </t>
              </tbody>
              <tfoot>
                <tr>
                  <th class="r-right r-total">TOTAL</th>
                  <th class="r-right r-total"><span t-esc="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></th>
                </tr>
                <tr>
                  <td colspan="2" class="r-small r-muted">Son: <t t-esc="o.currency_id.amount_to_text(o.amount)"/></td>
                </tr>
              </tfoot>
            </table>
          </div>

          <div class="r-section" t-if="obs">
            <div class="head">OBSERVACIONES</div>
            <div class="r-pre" style="padding:10px;"><t t-esc="obs"/></div>
          </div>

          <div class="r-section" t-if="'reconciled_invoice_ids' in o._fields and o.reconciled_invoice_ids">
            <div class="head">IMPUTACIONES</div>
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Detalle</th>
                  <th class="r-right">Importe</th>
                  <th class="r-right">Saldo</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="o.reconciled_invoice_ids" t-as="inv">
                  <td><t t-esc="(inv.invoice_date or inv.date).strftime('%d/%m/%Y') if (inv.invoice_date or inv.date) else ''"/></td>
                  <td><t t-esc="inv.name or inv.ref or inv.move_name"/></td>
                  <td class="r-right"><span t-esc="inv.amount_total_signed" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/></td>
                  <td class="r-right"><span t-esc="inv.amount_residual_signed" t-options="{'widget': 'monetary', 'display_currency': inv.currency_id}"/></td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="r-foot">
            <div class="sig">
              <div class="line"></div>
              <div class="r-small">FIRMA</div>
            </div>
            <div class="sig">
              <div class="line"></div>
              <div class="r-small">ACLARACION</div>
            </div>
          </div>
        </div>
      </t>
    </xpath>
  </template>
</odoo>
