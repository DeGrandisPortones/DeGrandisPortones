<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acción de lista filtrada por estado Pre-producción -->
    <record id="action_dflex_porton_preproduccion" model="ir.actions.act_window">
        <field name="name">Portones en Pre-producción</field>
        <field name="res_model">x_dflex.porton</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('x_estado', '=', 'preproduccion')]</field>
        <field name="context">{}</field>
    </record>

    <!-- Menú dentro de la app Portones existente -->
    <menuitem id="menu_dflex_porton_preproduccion"
              name="Pre-producción"
              parent="x_portones.menu_x_dflex_porton_root"
              action="action_dflex_porton_preproduccion"
              sequence="50"/>
</odoo>
