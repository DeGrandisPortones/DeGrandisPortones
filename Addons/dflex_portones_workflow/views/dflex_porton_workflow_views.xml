<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- VISTA LISTA: columna de estado y aprobaciones -->
    <record id="view_dflex_porton_list_workflow" model="ir.ui.view">
        <field name="name">x_dflex_porton.list.workflow</field>
        <field name="model">x_dflex.porton</field>
        <field name="inherit_id" ref="x_portones.x_dflex_porton_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="x_estado"/>
                <field name="x_aprob_comercial"/>
                <field name="x_aprob_planificacion"/>
                <field name="x_aprob_administracion"/>
            </xpath>
        </field>
    </record>

    <!-- VISTA FORMULARIO: botones de workflow -->
    <record id="view_dflex_porton_form_workflow" model="ir.ui.view">
        <field name="name">x_dflex_porton.form.workflow</field>
        <field name="model">x_dflex.porton</field>
        <field name="inherit_id" ref="x_portones.x_dflex_porton_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/group" position="after">
                <group string="Workflow DFLEX">
                    <field name="x_estado"/>

                    <group string="Aprobaciones">
                        <field name="x_aprob_comercial"/>
                        <field name="x_aprob_planificacion"/>
                        <field name="x_aprob_administracion"/>
                    </group>
                </group>

                <footer>
                    <!-- Estados principales -->
                    <button name="action_set_acopio"
                            string="Marcar acopio"
                            type="object"
                            class="btn-secondary"/>

                    <button name="action_set_pendiente_medicion"
                            string="Pendiente medición"
                            type="object"
                            class="btn-secondary"/>

                    <button name="action_set_pendiente_modif_comercial"
                            string="Pendiente modif. comercial"
                            type="object"
                            class="btn-secondary"/>

                    <!-- Cambios de estado posteriores -->
                    <button name="action_set_preproduccion"
                            string="A Pre-producción"
                            type="object"
                            class="btn-secondary"/>

                    <button name="action_set_produccion"
                            string="A Producción"
                            type="object"
                            class="btn-primary"/>

                    <!-- Botón estándar de Cerrar / Guardar -->
                    <button string="Guardar" type="object" name="action_save" class="btn-primary" special="save"/>
                </footer>
            </xpath>
        </field>
    </record>

</odoo>
