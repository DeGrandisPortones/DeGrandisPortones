<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista listado Portones con columnas de workflow -->
    <record id="view_dflex_porton_list_workflow" model="ir.ui.view">
        <field name="name">x_dflex_porton.list.workflow</field>
        <field name="model">x_dflex.porton</field>
        <field name="inherit_id" ref="x_portones.view_x_dflex_porton_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="x_estado"/>
                <field name="x_aprob_comercial"/>
                <field name="x_aprob_planificacion"/>
                <field name="x_aprob_administracion"/>
            </xpath>
        </field>
    </record>

    <!-- Vista formulario Portones con pestaña de workflow -->
    <record id="view_dflex_porton_form_workflow" model="ir.ui.view">
        <field name="name">x_dflex_porton.form.workflow</field>
        <field name="model">x_dflex.porton</field>
        <field name="inherit_id" ref="x_portones.view_x_dflex_porton_form"/>
        <field name="arch" type="xml">
            <!-- pestaña nueva -->
            <xpath expr="//notebook" position="inside">
                <page string="Workflow producción">
                    <group>
                        <field name="x_estado"/>
                    </group>
                    <group string="Aprobaciones">
                        <field name="x_aprob_comercial"/>
                        <field name="x_aprob_planificacion"/>
                        <field name="x_aprob_administracion"/>
                    </group>
                    <group string="Acciones rápidas">
                        <button string="Marcar Acopio" type="object"
                                name="action_marcar_acopio"
                                class="btn-secondary"/>
                        <button string="Pendiente medición" type="object"
                                name="action_iniciar_medicion"
                                class="btn-secondary"/>
                        <button string="Pendiente modificaciones" type="object"
                                name="action_marcar_pendiente_modif"
                                class="btn-secondary"/>
                        <button string="Pre-producción" type="object"
                                name="action_marcar_preproduccion"
                                class="btn-primary"/>
                        <button string="Producción" type="object"
                                name="action_marcar_produccion"
                                class="btn-primary"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
