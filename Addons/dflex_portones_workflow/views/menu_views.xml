<odoo>
    <data>

        <!-- Menú principal DFLEX Portones (si ya existe por otro módulo, podés borrar este bloque) -->
        <menuitem id="menu_dflex_portones_root"
                  name="DFLEX Portones"
                  sequence="10"/>

        <!-- Menú Workflow Portones -->
        <menuitem id="menu_dflex_portones_workflow"
                  name="Workflow Portones"
                  parent="menu_dflex_portones_root"
                  sequence="20"
                  action="action_dflex_portones_workflow"/>

        <!-- Acción de ventana para abrir lista de portones -->
        <record id="action_dflex_portones_workflow" model="ir.actions.act_window">
            <field name="name">Portones</field>
            <field name="res_model">x_dflex.porton</field>
            <field name="view_mode">list,form</field>
            <field name="context">{}</field>
        </record>

    </data>
</odoo>
