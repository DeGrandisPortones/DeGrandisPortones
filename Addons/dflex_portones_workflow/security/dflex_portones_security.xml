<odoo>
    <!-- Grupos -->
    <record id="group_dflex_comercial" model="res.groups">
        <field name="name">DFLEX - Comercial</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
    </record>

    <record id="group_dflex_planificacion" model="res.groups">
        <field name="name">DFLEX - Planificación</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
    </record>

    <record id="group_dflex_administracion" model="res.groups">
        <field name="name">DFLEX - Administración</field>
        <field name="category_id" ref="base.module_category_sales_management"/>
    </record>

    <!-- Reglas de acceso básicas -->
    <record id="rule_dflex_porton_workflow_company" model="ir.rule">
        <field name="name">DFLEX Porton Workflow multi-company</field>
        <field name="model_id" ref="model_dflex_porton_workflow"/>
        <field name="global" eval="False"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>