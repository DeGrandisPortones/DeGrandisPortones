<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_distributor_flag" model="ir.ui.view">
        <field name="name">sale.order.form.distributor.flag</field>
        <field name="model">sale.order</field>
        <!-- Esta referencia está bien: es la vista estándar del pedido de venta -->
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <!-- Insertamos nuestro campo dentro del primer <group> del <sheet> -->
            <xpath expr="//sheet/group" position="inside">
                <group string="Distribución">
                    <field name="is_distributor_delivery"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
