<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Plans -->
    <record id="view_sale_financing_plan_li" model="ir.ui.view">
        <field name="name">sale.financing.plan.li</field>
        <field name="model">sale.financing.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sale_financing_plan_form" model="ir.ui.view">
        <field name="name">sale.financing.plan.form</field>
        <field name="model">sale.financing.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Tarifas">
                            <field name="rate_ids">
                                <list editable="bottom">
                                    <field name="card_type"/>
                                    <field name="installments"/>
                                    <field name="rate_percent"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sale_financing_plan" model="ir.actions.act_window">
        <field name="name">Planes de financiación</field>
        <field name="res_model">sale.financing.plan</field>
        <field name="view_mode">li,form</field>
    </record>

    <menuitem id="menu_sale_financing_root"
              name="Financiación"
              parent="sale.sale_menu_config"
              sequence="80"/>

    <menuitem id="menu_sale_financing_plan"
              name="Planes y tarifas"
              parent="menu_sale_financing_root"
              action="action_sale_financing_plan"
              sequence="10"/>
</odoo>
