<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- Vista del lanzador con dos botones grandes -->
  <record id="view_x_dflex_porton_launcher_form" model="ir.ui.view">
    <field name="name">x_dflex.porton.launcher.form</field>
    <field name="model">x_dflex.porton.launcher</field>
    <field name="arch" type="xml">
      <form string="Portones">
        <sheet>
          <group>
            <h2>¿Qué querés hacer?</h2>
            <div class="oe_button_box" name="button_box" style="display:flex; gap:16px;">
              <button name="action_open_list" type="object" class="btn btn-primary" string="Ver listado"/>
              <button name="action_open_import" type="object" class="btn btn-secondary" string="Importar desde CSV"/>
            </div>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Acción que abre el lanzador (no modal) -->
  <record id="action_x_dflex_porton_launcher" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">x_dflex.porton.launcher</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
  </record>
</odoo>
