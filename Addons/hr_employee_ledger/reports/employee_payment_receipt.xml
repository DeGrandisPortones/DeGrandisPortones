
<odoo>
  <record id="action_report_employee_payment_receipt" model="ir.actions.report">
    <field name="name">Recibo de Anticipo</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">hr_employee_ledger.report_employee_payment_receipt</field>
    <field name="report_file">hr_employee_ledger.report_employee_payment_receipt</field>
    <field name="print_report_name">'Recibo - %s - %s' % (object.employee_id.name, object.date)</field>
  </record>

  <template id="report_employee_payment_receipt">
    <t t-call="web.external_layout">
      <t t-set="doc" t-value="doc"/>
      <div class="page">
        <h2 style="text-align:center;">Recibo de Anticipo</h2>
        <p>
          <strong>Empleado:</strong> <span t-esc="doc.employee_id.name"/>
          <t t-if="doc.employee_id.identification_id"> — <strong>Documento:</strong> <span t-esc="doc.employee_id.identification_id"/></t><br/>
          <strong>Fecha:</strong> <span t-esc="doc.date"/> —
          <strong>Tipo de pago:</strong> <t t-esc="{'a':'A (dinero)','b':'B (alimentos)'}.get(doc.payment_type, doc.payment_type)"/>
        </p>
        <table class="table table-sm o_main_table">
          <thead><tr><th>Concepto</th><th>Cuenta de salida</th><th style="text-align:right;">Importe</th></tr></thead>
          <tbody><tr>
            <td><span t-esc="doc.concept"/></td>
            <td><span t-esc="doc.account_src_id.display_name"/></td>
            <td style="text-align:right;"><span t-esc="formatLang(doc.amount, monetary=True, currency_obj=doc.currency_id)"/></td>
          </tr></tbody>
        </table>
        <div style="margin-top:40px; display:flex; justify-content:space-between;">
          <div style="width:45%; text-align:center;"><div style="border-top:1px solid #000; padding-top:8px;">Firma RRHH</div></div>
          <div style="width:45%; text-align:center;"><div style="border-top:1px solid #000; padding-top:8px;">Firma del Empleado</div></div>
        </div>
      </div>
    </t>
  </template>
</odoo>
