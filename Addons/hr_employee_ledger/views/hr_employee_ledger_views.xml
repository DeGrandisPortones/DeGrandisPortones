
<odoo>
  <record id="view_hr_employee_ledger_move_list" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list string="Movimientos CC Empleados">
        <field name="name"/>
        <field name="date"/>
        <field name="employee_id"/>
        <field name="payment_type"/>
        <field name="account_src_id"/>
        <field name="amount"/>
        <field name="state"/>
        <field name="batch_id"/>
        <field name="account_move_id"/>
      </list>
    </field>
  </record>

  <record id="view_hr_employee_ledger_move_form" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.form</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <form string="Movimiento CC Empleado">
        <header>
          <button name="action_post" type="object" string="Asentar" class="btn-primary" invisible="state != 'draft'"/>
          <button name="action_print_receipt" type="object" string="Imprimir recibo" class="btn-secondary" invisible="state == 'draft'"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel"/>
        </header>
        <sheet>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name"/></h1>
          </div>
          <group>
            <group>
              <field name="employee_id" required="1"/>
              <field name="date" required="1"/>
              <field name="payment_type" required="1"/>
            </group>
            <group>
              <field name="account_src_id" required="1"/>
              <field name="amount" required="1"/>
            </group>
          </group>
          <group>
            <field name="concept" required="1"/>
            <field name="narration"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
