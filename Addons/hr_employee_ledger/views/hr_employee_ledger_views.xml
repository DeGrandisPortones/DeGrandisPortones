<odoo>

        <record id="action_hr_employee_ledger_batch_wizard" model="ir.actions.act_window">
            <field name="name">Cierre mensual (A/B)</field>
            <field name="res_model">hr.employee.ledger.batch.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>
    
    <!-- Acción y menú -->
    <record id="action_hr_employee_ledger_move" model="ir.actions.act_window">
        <field name="name">Cuentas Corrientes de Empleados</field>
        <field name="res_model">hr.employee.ledger.move</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_hr_employee_ledger_root" name="Cuentas Corrientes" parent="hr.menu_hr_root" sequence="60"/>
    <menuitem id="menu_hr_employee_ledger_moves" name="Movimientos" parent="menu_hr_employee_ledger_root" action="action_hr_employee_ledger_move" sequence="10"/>
        <menuitem id="menu_hr_employee_ledger_batch" name="Cierre mensual (A/B)" parent="menu_hr_employee_ledger_root" action="action_hr_employee_ledger_batch_wizard" sequence="20"/>

    <!-- Vista tree -->
    <record id="view_hr_employee_ledger_move_tree" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.tree</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list string="Movimientos CC Empleados" create="true">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="journal_id"/>
                    <field name="payment_type"/>
                    <field name="payment_type"/>
                <field name="amount_debit"/>
                <field name="amount_credit"/>
                <field name="balance"/>
                <field name="state"/>
                <field name="account_move_id"/>
            </list>
        </field>
    </record>

    <!-- Vista form -->
    <record id="view_hr_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento CC Empleado">
                <header>
                    <button name="action_post" type="object" string="Asentar" class="btn-primary" states="draft"/>
                        <button name="action_print_receipt" type="object" string="Imprimir recibo" class="btn-secondary" states="draft,posted"/>
                    <button name="action_cancel" type="object" string="Cancelar" states="draft,posted"/>
                    <button name="action_set_to_draft" type="object" string="Volver a borrador" states="cancel"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" options="{'no_open': False, 'no_create': False}"/>
                            <field name="date"/>
                            <field name="journal_id"/>
                    <field name="payment_type"/>
                    <field name="payment_type"/>
                        </group>
                        <group>
                            <field name="post_in_accounting"/>
                            <field name="account_move_id" readonly="1" context="{'form_view_ref':'account.view_move_form'}"/>
                            <field name="currency_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Líneas">
                            <field name="line_ids" context="{'default_employee_id': employee_id, 'default_currency_id': currency_id}">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type"/>
                                    <field name="name"/>
                                    <field name="account_id" attrs="{'required':[('parent.post_in_accounting','=',True)], 'invisible':[('parent.post_in_accounting','=',False)]}"/>
                                    <field name="debit"/>
                                    <field name="credit"/>
                                    <field name="analytic_account_id" groups="analytic.group_analytic_accounting"/>
                                    <field name="analytic_tag_ids" widget="many2many_tags" groups="analytic.group_analytic_accounting"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notas">
                            <field name="narration"/>
                        </page>
                    </notebook>
                    <group>
                        <group>
                            <field name="amount_debit" readonly="1"/>
                            <field name="amount_credit" readonly="1"/>
                        </group>
                        <group>
                            <field name="balance" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vistas de línea (no se definen explicitamente tree/form separadas ya que se usan inline) -->

    <!-- Botón inteligente en empleado -->
    <record id="view_hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet//div[@name='button_box']" position="inside">
                <button type="object" name="action_view_employee_ledger"
                        class="oe_stat_button" icon="fa-book">
                    <field name="ledger_move_count" string="Mov." widget="statinfo"/>
                    <div class="o_form_field o_stat_info">
                        <span class="o_stat_text">Cuenta corriente</span>
                        <span class="o_stat_value"><field name="ledger_balance"/></span>
                    </div>
                </button>
            </xpath>
        </field>
    </record>
</odoo>