<odoo>
  <record id="action_hr_employee_ledger_move" model="ir.actions.act_window">
    <field name="name">Cuentas Corrientes de Empleados</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form,pivot,graph</field>
    <field name="context">{}</field>
  </record>

  <record id="action_hr_employee_ledger_batch_wizard" model="ir.actions.act_window">
    <field name="name">Cierre mensual (A/B)</field>
    <field name="res_model">hr.employee.ledger.batch.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <menuitem id="menu_hr_employee_ledger_root" name="Cuentas Corrientes" parent="hr.menu_hr_root" sequence="60"/>
  <menuitem id="menu_hr_employee_ledger_moves" name="Movimientos" parent="menu_hr_employee_ledger_root" action="action_hr_employee_ledger_move" sequence="10"/>
  <menuitem id="menu_hr_employee_ledger_batch" name="Cierre mensual (A/B)" parent="menu_hr_employee_ledger_root" action="action_hr_employee_ledger_batch_wizard" sequence="20"/>

  <record id="view_hr_employee_ledger_move_list" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list string="Movimientos CC Empleados">
        <field name="name"/>
        <field name="date"/>
        <field name="employee_id"/>
        <field name="payment_type"/>
        <field name="account_src_id"/>
        <field name="amount"/>
        <field name="state"/>
        <field name="batch_id"/>
        <field name="account_move_id"/>
      </list>
    </field>
  </record>

  <record id="view_hr_employee_ledger_move_form" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.form</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <form string="Movimiento CC Empleado">
        <header>
          <button name="action_post" type="object" string="Asentar" class="btn-primary" invisible="state != 'draft'"/>
          <button name="action_cancel" type="object" string="Cancelar" invisible="not (state in ['draft','posted'])"/>
          <button name="action_set_to_draft" type="object" string="Volver a borrador" invisible="state != 'cancel'"/>
          <button name="action_print_receipt" type="object" string="Imprimir recibo" class="btn-secondary" invisible="state == 'draft'"/>
          <field name="state" widget="statusbar" statusbar_visible="draft,posted,cancel"/>
        </header>
        <sheet>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name"/></h1>
          </div>
          <group>
            <group>
              <field name="employee_id" required="1"/>
              <field name="date" required="1"/>
              <field name="payment_type" required="1"/>
            </group>
            <group>
              <field name="account_src_id" required="1"/>
              <field name="amount" required="1"/>
            </group>
          </group>
          <group>
            <field name="concept" required="1"/>
            <field name="narration"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_hr_employee_form_inherit_ledger" model="ir.ui.view">
    <field name="name">hr.employee.form.ledger.inherit</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.view_employee_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet//div[@name='button_box']" position="inside">
        <button type="object" name="action_view_employee_ledger" class="oe_stat_button" icon="fa-book">
          <field name="ledger_move_count" string="Mov." widget="statinfo"/>
          <div class="o_form_field o_stat_info">
            <span class="o_stat_text">Cuenta corriente</span>
            <span class="o_stat_value"><field name="ledger_balance"/></span>
          </div>
        </button>
      </xpath>
    </field>
  </record>
</odoo>
