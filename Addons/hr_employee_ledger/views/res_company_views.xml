<odoo>
  <record id="view_company_form_inherit_hr_employee_ledger" model="ir.ui.view">
    <field name="name">res.company.form.inherit.hr.employee.ledger</field>
    <field name="model">res.company</field>
    <field name="inherit_id" ref="base.view_company_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet/notebook" position="inside">
        <page string="RRHH - Anticipos">
          <group>
            <field name="employee_batch_journal_id"/>
            <field name="employee_advance_account_a_id"/>
            <field name="employee_advance_account_b_id"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>