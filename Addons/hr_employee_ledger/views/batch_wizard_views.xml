<odoo>
    <record id="view_hr_employee_ledger_batch_wizard" model="ir.ui.view">
        <field name="name">hr.employee.ledger.batch.wizard.form</field>
        <field name="model">hr.employee.ledger.batch.wizard</field>
        <field name="arch" type="xml">
            <form string="Cierre mensual de anticipos">
                <group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="payment_type"/>
                    </group>
                    <group>
                        <field name="journal_id"/>
                        <field name="memo"/>
                    </group>
                </group>
                <footer>
                    <button name="action_generate" type="object" class="btn-primary" string="Generar asiento"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>