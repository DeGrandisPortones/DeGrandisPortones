
<odoo>
  <record id="view_hr_employee_ledger_batch_wizard_form" model="ir.ui.view">
    <field name="name">hr.employee.ledger.batch.wizard.form</field>
    <field name="model">hr.employee.ledger.batch.wizard</field>
    <field name="arch" type="xml">
      <form string="Cierre mensual (A/B)">
        <group>
          <group>
            <field name="payment_type"/>
            <field name="date_from"/>
            <field name="date_to"/>
            <field name="include_drafts"/>
            <field name="confirm_drafts" attrs="{'invisible':[('include_drafts','=',False)]}"/>
          </group>
          <group>
            <field name="journal_id" context="{'default_company_id': company_id}"/>
            <field name="debit_account_id" context="{'default_company_id': company_id}"/>
            <field name="total_moves" readonly="1"/>
            <field name="total_amount" readonly="1"/>
          </group>
        </group>
        <notebook>
          <page string="Resumen por cuenta">
            <field name="line_ids" readonly="1">
              <list>
                <field name="account_id"/>
                <field name="count_moves"/>
                <field name="amount"/>
              </list>
            </field>
          </page>
          <page string="Detalle por empleado">
            <field name="employee_line_ids" readonly="1">
              <list>
                <field name="employee_id"/>
                <field name="count_moves"/>
                <field name="amount"/>
              </list>
            </field>
          </page>
        </notebook>
        <footer>
          
          <button name="action_generate" type="object" string="Generar lote" class="btn-primary"/>
          <button string="Cerrar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>
