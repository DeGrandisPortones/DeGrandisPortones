<odoo>
  <record id="view_account_payment_form_checks" model="ir.ui.view">
    <field name="name">account.payment.form.checks</field>
    <field name="model">account.payment</field>
    <field name="inherit_id" ref="account.view_account_payment_form"/>
    <field name="arch" type="xml">
      <!-- Insertamos un nuevo notebook con la pestaña Cheques -->
      <xpath expr="//sheet" position="inside">
        <notebook>
          <page string="Cheques">
            <field name="check_line_ids" context="{'default_payment_id': active_id}">
              <tree editable="bottom">
                <field name="number"/>
                <field name="bank_id"/>
                <field name="issuer"/>
                <field name="issuer_vat"/>
                <field name="issue_date"/>
                <field name="payment_date"/>
                <field name="due_date"/>
                <field name="amount"/>
              </tree>
              <form>
                <group>
                  <field name="number"/>
                  <field name="bank_id"/>
                  <field name="issuer"/>
                  <field name="issuer_vat"/>
                </group>
                <group>
                  <field name="issue_date"/>
                  <field name="payment_date"/>
                  <field name="due_date"/>
                  <field name="amount"/>
                </group>
              </form>
            </field>
          </page>
        </notebook>
      </xpath>
    </field>
  </record>
</odoo>