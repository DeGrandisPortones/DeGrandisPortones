<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_presupuestador_rubro_list" model="ir.ui.view">
            <field name="name">presupuestador.rubro.list</field>
            <field name="model">presupuestador.rubro</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="qty_mode"/>
                    <field name="product_category_id"/>
                    <field name="active"/>
                </list>
            </field>
        </record>

        <record id="view_presupuestador_rubro_form" model="ir.ui.view">
            <field name="name">presupuestador.rubro.form</field>
            <field name="model">presupuestador.rubro</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="qty_mode"/>
                            <field name="product_category_id"/>
                            <field name="product_tag_ids" widget="many2many_tags"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_presupuestador_rubros" model="ir.actions.act_window">
            <field name="name">Rubros</field>
            <field name="res_model">presupuestador.rubro</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="view_presupuestador_pedido_list" model="ir.ui.view">
            <field name="name">presupuestador.pedido.list</field>
            <field name="model">presupuestador.pedido</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="state"/>
                    <field name="partner_id"/>
                    <field name="pricelist_id"/>
                    <field name="coeficiente"/>
                    <field name="m2"/>
                    <field name="amount_total"/>
                    <field name="create_date"/>
                </list>
            </field>
        </record>

        <record id="view_presupuestador_pedido_form" model="ir.ui.view">
            <field name="name">presupuestador.pedido.form</field>
            <field name="model">presupuestador.pedido</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="draft,sent,done,cancel"/>
                        <button name="action_recompute_lines" type="object" string="Recalcular líneas" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="pricelist_id"/>
                            <field name="coeficiente"/>
                        </group>
                        <group string="Medidas">
                            <field name="sistema"/>
                            <field name="ancho"/>
                            <field name="alto"/>
                            <field name="peso_m2"/>
                            <field name="m2" readonly="1"/>
                            <field name="peso_total" readonly="1"/>
                        </group>

                        <notebook>
                            <page string="Líneas">
                                <field name="line_ids">
                                    <list editable="bottom">
                                        <field name="rubro_id"/>
                                        <field name="product_id"/>
                                        <field name="qty"/>
                                        <field name="precio_distr" readonly="1"/>
                                        <field name="price_unit" readonly="1"/>
                                        <field name="tax_ids" widget="many2many_tags"/>
                                        <field name="price_total" readonly="1"/>
                                        <field name="obs"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>

                        <group class="oe_subtotal_footer">
                            <field name="amount_untaxed" readonly="1"/>
                            <field name="amount_tax" readonly="1"/>
                            <field name="amount_total" readonly="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_presupuestador_pedidos" model="ir.actions.act_window">
            <field name="name">Presupuestos</field>
            <field name="res_model">presupuestador.pedido</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_presupuestador_root" name="Presupuestador SPA" sequence="60"/>
        <menuitem id="menu_presupuestador_pedidos" name="Presupuestos" parent="menu_presupuestador_root"
                  action="action_presupuestador_pedidos" sequence="10"/>
        <menuitem id="menu_presupuestador_rubros" name="Rubros" parent="menu_presupuestador_root"
                  action="action_presupuestador_rubros" sequence="20"/>
    </data>
</odoo>
