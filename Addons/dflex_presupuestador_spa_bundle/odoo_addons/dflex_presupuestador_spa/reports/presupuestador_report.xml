<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record id="action_report_presupuestador_pedido" model="ir.actions.report">
      <field name="name">Presupuesto</field>
      <field name="model">presupuestador.pedido</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">dflex_presupuestador_spa.report_presupuestador_pedido</field>
      <field name="report_file">dflex_presupuestador_spa.report_presupuestador_pedido</field>
      <field name="print_report_name">'Presupuesto_%s' % (object.name)</field>
    </record>

    <template id="report_presupuestador_pedido">
      <t t-call="web.basic_layout">
        <t t-set="doc" t-value="doc_ids and docs[0]"/>
        <div class="page">
          <h2>Presupuesto: <span t-esc="doc.name"/></h2>
          <p><strong>Cliente/Distribuidor:</strong> <span t-esc="doc.partner_id.display_name"/></p>

          <table class="table table-sm">
            <tbody>
              <tr><th style="width: 25%;">Sistema</th><td><span t-esc="doc.sistema or ''"/></td></tr>
              <tr><th>Medidas</th><td>Ancho: <span t-esc="doc.ancho"/> m | Alto: <span t-esc="doc.alto"/> m | m²: <span t-esc="doc.m2"/></td></tr>
              <tr><th>Peso</th><td>kg/m²: <span t-esc="doc.peso_m2"/> | Total: <span t-esc="doc.peso_total"/> kg</td></tr>
              <tr><th>Coeficiente</th><td><span t-esc="doc.coeficiente"/> %</td></tr>
            </tbody>
          </table>

          <h3>Detalle</h3>
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Descripción</th>
                <th class="text-right">Cant.</th>
                <th class="text-right">Precio</th>
                <th class="text-right">Total</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="doc.line_ids" t-as="l">
                <tr>
                  <td>
                    <strong t-esc="l.product_id.display_name"/>
                    <t t-if="l.obs"><div class="text-muted" style="font-size: 10px;" t-esc="l.obs"/></t>
                  </td>
                  <td class="text-right" t-esc="l.qty"/>
                  <td class="text-right"><span t-esc="l.price_unit"/> <span t-esc="doc.currency_id.symbol"/></td>
                  <td class="text-right"><span t-esc="l.price_total"/> <span t-esc="doc.currency_id.symbol"/></td>
                </tr>
              </t>
            </tbody>
          </table>

          <div style="margin-top: 1rem;">
            <table class="table table-sm" style="width: 40%; margin-left: auto;">
              <tbody>
                <tr><th>Subtotal</th><td class="text-right"><span t-esc="doc.amount_untaxed"/> <span t-esc="doc.currency_id.symbol"/></td></tr>
                <tr><th>IVA</th><td class="text-right"><span t-esc="doc.amount_tax"/> <span t-esc="doc.currency_id.symbol"/></td></tr>
                <tr><th>Total</th><td class="text-right"><strong><span t-esc="doc.amount_total"/> <span t-esc="doc.currency_id.symbol"/></strong></td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </t>
    </template>

  </data>
</odoo>
