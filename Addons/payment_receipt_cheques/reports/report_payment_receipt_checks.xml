<odoo>
  <template id="report_payment_receipt_document_inherit_checks"
            inherit_id="account.report_payment_receipt_document">
    <xpath expr="//div[contains(@class,'page')]" position="inside">
      <t t-if="o.has_checks">
        <h3 class="mt16 mb8">Cheques recibidos</h3>
        <table class="table table-sm o_main_table">
          <thead>
            <tr>
              <th>Número</th>
              <th>Banco</th>
              <th>Emisor</th>
              <th>CUIT Emisor</th>
              <th>F. pago</th>
              <th>Vencimiento</th>
              <th class="text-end">Importe</th>
            </tr>
          </thead>
          <tbody>
            <tr t-foreach="o.check_line_ids" t-as="c">
              <td><t t-esc="c.number or ''"/></td>
              <td><t t-esc="(c.bank_id and c.bank_id.name) or ''"/></td>
              <td><t t-esc="c.issuer or ''"/></td>
              <td><t t-esc="c.issuer_vat or ''"/></td>
              <td><t t-esc="c.payment_date or ''"/></td>
              <td><t t-esc="c.due_date or ''"/></td>
              <td class="text-end">
                <span t-esc="c.amount"
                      t-options='{"widget": "monetary", "display_currency": o.currency_id}'/>
              </td>
            </tr>
          </tbody>
        </table>
      </t>
    </xpath>
  </template>
</odoo>