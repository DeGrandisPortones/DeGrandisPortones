<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="res_config_settings_view_form_ar_padron" model="ir.ui.view">
    <field name="name">res.config.settings.view.form.ar.padron</field>
    <field name="model">res.config.settings</field>
    <field name="inherit_id" ref="base.setup"/>
    <field name="arch" type="xml">
      <xpath expr="//div[@id='settings']//div[hasclass('app_settings_block')][1]" position="after">
        <div class="app_settings_block" data-string="AFIP/ARCA Padrón" string="AFIP/ARCA Padrón">
          <h2>AFIP/ARCA – Padrón</h2>
          <div class="row mt16 o_settings_container">
            <div class="col-12 col-lg-6">
              <div class="o_setting_box">
                <div class="o_setting_left_pane">
                  <field name="ar_padron_env"/>
                </div>
                <div class="o_setting_right_pane">
                  <label for="ar_padron_env"/>
                  <div class="text-muted">Seleccioná el entorno a usar para la consulta.</div>
                </div>
              </div>
              <div class="o_setting_box">
                <div class="o_setting_left_pane">
                  <field name="ar_padron_use_mock"/>
                </div>
                <div class="o_setting_right_pane">
                  <label for="ar_padron_use_mock"/>
                  <div class="text-muted">Si está activo, la consulta devuelve datos de ejemplo.</div>
                </div>
              </div>
              <div class="o_setting_box">
                <div class="o_setting_left_pane">
                  <field name="ar_padron_cert" filename="ar_padron_cert_fname"/>
                  <field name="ar_padron_key" filename="ar_padron_key_fname"/>
                  <field name="ar_padron_key_password"/>
                </div>
                <div class="o_setting_right_pane">
                  <label for="ar_padron_cert"/>
                  <div class="text-muted">Certificado y clave para WSAA (requeridos para test/prod).</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </xpath>
    </field>
  </record>
</odoo>