<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_partner_form_ar_padron" model="ir.ui.view">
    <field name="name">res.partner.form.ar.padron</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
      <xpath expr="//header" position="inside">
        <button name="action_ar_update_from_padron"
                type="object"
                string="Actualizar desde Padrón (AFIP/ARCA)"
                class="btn-primary"
                attrs="{'invisible': ['|', ('country_id.code', '!=', 'AR'), ('vat', '=', False)]}"/>
      </xpath>
    </field>
  </record>
</odoo>