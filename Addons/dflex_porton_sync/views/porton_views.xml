<odoo>
    <record id="view_porton_tree_dflexsync" model="ir.ui.view">
        <field name="name">x_dflex.porton.tree.dflexsync</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="x_studio_sale_order_id"/>
                <field name="x_name"/>
                <field name="x_nota_de_venta"/>
                <field name="x_base_value"/>
                <field name="x_computed_value"/>
                <field name="x_formula_js" widget="porton_formula_js"/>
            </list>
        </field>
    </record>

    <record id="view_porton_form_dflexsync" model="ir.ui.view">
        <field name="name">x_dflex.porton.form.dflexsync</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <form string="Portón Dflex (Sync)">
                <sheet>
                    <group>
                        <field name="x_studio_sale_order_id"/>
                        <field name="x_name"/>
                        <field name="x_nota_de_venta"/>
                        <field name="x_base_value"/>
                        <field name="x_computed_value"/>
                        <field name="x_formula_js" widget="porton_formula_js"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_porton_dflexsync" model="ir.actions.act_window">
        <field name="name">Portones Dflex (Sync)</field>
        <field name="res_model">x_dflex.porton</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_porton_tree_dflexsync"/>
    </record>

    <menuitem id="menu_dflex_porton_root"
              name="Portones Dflex"
              parent="sale.sale_menu_root"
              action="action_porton_dflexsync"/>
</odoo>