<odoo>
    <record id="view_porton_tree" model="ir.ui.view">
        <field name="name">x_dflex.porton.li</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <li editable="bottom">
                <field name="sale_order_id"/>
                <field name="base_value"/>
                <field name="computed_value"/>
                <field name="formula_js" widget="porton_formula_js"/>
            </li>
        </field>
    </record>

    <record id="view_porton_form" model="ir.ui.view">
        <field name="name">x_dflex.porton.form</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <form string="Portón Dflex">
                <sheet>
                    <group>
                        <field name="sale_order_id"/>
                        <field name="base_value"/>
                        <field name="computed_value"/>
                        <field name="formula_js" widget="porton_formula_js"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_porton" model="ir.actions.act_window">
        <field name="name">Portones Dflex</field>
        <field name="res_model">x_dflex.porton</field>
        <field name="view_mode">li,form</field>
    </record>

    <menuitem id="menu_dflex_porton_root"
              name="Portones Dflex"
              parent="sale.sale_menu_root"
              action="action_porton"/>
</odoo>