<odoo>
  <!-- List view for account.payment.check.line -->
  <record id="view_payment_check_line_list" model="ir.ui.view">
    <field name="name">account.payment.check.line.list</field>
    <field name="model">account.payment.check.line</field>
    <field name="arch" type="xml">
      <list editable="bottom">
        <field name="number"/>
        <field name="bank_id"/>
        <field name="issuer"/>
        <field name="issuer_vat"/>
        <field name="issue_date"/>
        <field name="payment_date"/>
        <field name="due_date"/>
        <field name="amount"/>
      </list>
    </field>
  </record>

  <!-- Form view for account.payment.check.line -->
  <record id="view_payment_check_line_form" model="ir.ui.view">
    <field name="name">account.payment.check.line.form</field>
    <field name="model">account.payment.check.line</field>
    <field name="arch" type="xml">
      <form string="Cheque">
        <group>
          <field name="number"/>
          <field name="bank_id"/>
          <field name="issuer"/>
          <field name="issuer_vat"/>
        </group>
        <group>
          <field name="issue_date"/>
          <field name="payment_date"/>
          <field name="due_date"/>
          <field name="amount"/>
        </group>
      </form>
    </field>
  </record>

  <!-- Inherit payment form and add our own notebook under //sheet -->
  <record id="view_account_payment_form_checks" model="ir.ui.view">
    <field name="name">account.payment.form.checks</field>
    <field name="model">account.payment</field>
    <field name="inherit_id" ref="account.view_account_payment_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <notebook>
          <page string="Cheques">
            <field name="check_line_ids"
                   mode="list,form"
                   context="{'default_payment_id': active_id,
                             'list_view_ref': 'payment_receipt_cheques.view_payment_check_line_list',
                             'form_view_ref': 'payment_receipt_cheques.view_payment_check_line_form'}"/>
          </page>
        </notebook>
      </xpath>
    </field>
  </record>
</odoo>