<odoo>
  <template id="report_payment_receipt_document_modern" inherit_id="account.report_payment_receipt_document">
    <xpath expr="//t[@t-call='web.external_layout' or @t-call='web.external_layout_clean']" position="replace">
      <t t-call="web.external_layout">
        <t t-set="o" t-value="o"/>
        <style>
          .r-wrap { padding: 2px 0; }
          .r-header { display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
          .r-title { font-size:20px; font-weight:700; letter-spacing:.5px; }
          .r-subpill { padding:3px 10px; border:1px solid #e5e7eb; border-radius:9999px; font-size:11px; }
          .r-muted { color:#6b7280; }
          .r-small { font-size:11px; }
          .r-kv td { padding:2px 6px; vertical-align:top; }
          .r-section { margin-top:14px; border:1px solid #e5e7eb; border-radius:8px; overflow:hidden; }
          .r-section > .head { background:#f3f4f6; font-weight:600; padding:8px 10px; border-bottom:1px solid #e5e7eb; }
          .r-section table { width:100%; border-collapse:collapse; }
          .r-section th, .r-section td { padding:8px 10px; border-bottom:1px solid #e5e7eb; }
          .r-right { text-align:right; }
          .r-pre { white-space:pre-line; }
          .r-badge { background:#e8f5e9; color:#166534; border:1px solid #bbf7d0; padding:2px 8px; border-radius:9999px; font-size:11px; }
          .r-total { font-size:14px; font-weight:700; }
          .r-foot { margin-top:18px; display:flex; gap:16px; }
          .r-foot .sig { flex:1; text-align:center; }
          .r-foot .sig .line { border-top:1px solid #9ca3af; margin:20px 20px 6px; }
          .r-mono { font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace; }
        </style>

        <div class="page r-wrap">
          <div class="r-header">
            <div>
              <div class="r-title">ORDEN DE COBRANZA</div>
              <table class="r-kv r-small">
                <tr><td class="r-muted">N°</td><td class="r-mono"><t t-esc="o.name"/></td></tr>
                <tr><td class="r-muted">Cliente</td><td><t t-esc="o.partner_id.display_name"/></td></tr>
                <tr><td class="r-muted">Fecha</td><td><t t-esc="(o.date or o.create_date).strftime('%d/%m/%Y') if (o.date or o.create_date) else ''"/></td></tr>
              </table>
            </div>
            <div>
              <table class="r-kv r-small">
                <tr><td class="r-muted">CUIT</td><td><t t-esc="o.partner_id.vat or ''"/></td></tr>
                <tr t-if="getattr(o.partner_id, 'l10n_ar_afip_responsibility_type_id', False)">
                  <td class="r-muted">Sit. IVA</td>
                  <td><t t-esc="o.partner_id.l10n_ar_afip_responsibility_type_id.name or ''"/></td>
                </tr>
                <tr><td class="r-muted">Domicilio</td><td><t t-esc="o.partner_id.contact_address or ''"/></td></tr>
                <tr><td class="r-muted">Teléfonos</td>
                  <td>
                    <t t-if="o.partner_id.phone"><t t-esc="o.partner_id.phone"/></t>
                    <t t-if="o.partner_id.mobile"> / <t t-esc="o.partner_id.mobile"/></t>
                  </td>
                </tr>
              </table>
            </div>
            <div class="r-small r-muted" style="text-align:right;">
              <t t-if="o.company_id.logo">
                <img t-att-src="'data:image/png;base64,%s' % (o.company_id.logo)" style="max-height:52px;"/><br/>
              </t>
              <t t-esc="o.company_id.name"/><br/>
              <t t-esc="o.company_id.street or ''"/><t t-if="o.company_id.street2">, <t t-esc="o.company_id.street2"/></t><br/>
              <t t-esc="o.company_id.city or ''"/><t t-if="o.company_id.state_id">, <t t-esc="o.company_id.state_id.name"/></t>
              <t t-if="o.company_id.zip"> <t t-esc="o.company_id.zip"/></t><br/>
              CUIT: <t t-esc="o.company_id.vat or ''"/><br/>
              <t t-if="o.company_id.email"><t t-esc="o.company_id.email"/></t><br/>
              <t t-if="o.company_id.website"><t t-esc="o.company_id.website"/></t><br/>
              <t t-if="o.company_id.phone">Contacto: <t t-esc="o.company_id.phone"/></t>
            </div>
          </div>

          <div class="r-section">
            <div class="head">MEDIOS DE PAGO</div>
            <table>
              <thead>
                <tr>
                  <th>Detalle</th>
                  <th class="r-right">Importe</th>
                </tr>
              </thead>
              <tbody>
                <t t-if="getattr(o, 'check_line_ids', False) and o.check_line_ids">
                  <tr t-foreach="o.check_line_ids" t-as="c">
                    <td>
                      <t t-if="c.number">CHEQUE ELECTRONICO Nº <t t-esc="c.number"/></t>
                      <t t-if="c.bank_id"> - <t t-esc="c.bank_id.name"/></t>
                      <t t-if="c.due_date"> - <t t-esc="c.due_date.strftime('%d/%m/%Y')"/></t>
                    </td>
                    <td class="r-right">
                      <span t-esc="c.amount" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                    </td>
                  </tr>
                </t>

                <t t-if="o.payment_method_line_id and ('transfer' in (o.payment_method_line_id.code or '').lower() or 'manual' in (o.payment_method_line_id.code or '').lower())">
                  <tr>
                    <td>
                      <t>TRANSFERENCIA BANCARIA</t>
                      <t t-if="o.ref or o.payment_reference"> N°: <t t-esc="o.ref or o.payment_reference"/></t>
                      <t t-if="o.journal_id and o.journal_id.bank_id"> | <t t-esc="o.journal_id.bank_id.name"/></t>
                      <t t-if="o.journal_id and o.journal_id.bank_account_id">
                         - <t t-esc="o.journal_id.bank_account_id.acc_number"/>
                      </t>
                    </td>
                    <td class="r-right">
                      <span t-esc="o.amount" t-options='{"widget":"monetary","display_currency":o.currency_id}'/>
                    </td>
                  </tr>
                </t>

                <t t-if="not (getattr(o, 'check_line_ids', False) and o.check_line_ids) and not (o.payment_method_line_id and ('transfer' in (o.payment_method_line_id.code or '').lower() or 'manual' in (o.payment_method_line_id.code or '').lower()))">
                  <tr>
                    <td>
                      <t t-esc="o.payment_method_line_id and o.payment_method_line_id.name or 'Pago'"/>
                    </td>
                    <td class="r-right">
                      <span t-esc="o.amount" t-options='{"widget':'monetary','display_currency':o.currency_id}'/>
                    </td>
                  </tr>
                </t>
              </tbody>
              <tfoot>
                <tr>
                  <th class="r-right r-total">TOTAL</th>
                  <th class="r-right r-total"><span t-esc="o.amount" t-options='{"widget":"monetary","display_currency":o.currency_id}'/></th>
                </tr>
                <tr>
                  <td colspan="2" class="r-small r-muted">
                    Son: <t t-esc="o.currency_id.amount_to_text(o.amount)"/>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>

          <div class="r-section" t-if="o.ref or o.narration or o.communication">
            <div class="head">OBSERVACIONES</div>
            <div class="r-pre" style="padding:10px;">
              <t t-esc="o.narration or o.communication or o.ref"/>
            </div>
          </div>

          <div class="r-section" t-if="getattr(o, 'reconciled_invoice_ids', False) and o.reconciled_invoice_ids">
            <div class="head">IMPUTACIONES</div>
            <table>
              <thead>
                <tr>
                  <th>Fecha</th>
                  <th>Detalle</th>
                  <th class="r-right">Importe</th>
                  <th class="r-right">Saldo</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="o.reconciled_invoice_ids" t-as="inv">
                  <td><t t-esc="inv.invoice_date or inv.date or ''"/></td>
                  <td><t t-esc="inv.name or inv.ref or inv.move_name"/></td>
                  <td class="r-right"><span t-esc="inv.amount_total_signed" t-options='{"widget":"monetary","display_currency":inv.currency_id}'/></td>
                  <td class="r-right"><span t-esc="inv.amount_residual_signed" t-options='{"widget":"monetary","display_currency":inv.currency_id}'/></td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="r-foot">
            <div class="sig">
              <div class="line"></div>
              <div class="r-small">FIRMA</div>
            </div>
            <div class="sig">
              <div class="line"></div>
              <div class="r-small">ACLARACION</div>
            </div>
          </div>
        </div>
      </t>
    </xpath>
  </template>
</odoo>