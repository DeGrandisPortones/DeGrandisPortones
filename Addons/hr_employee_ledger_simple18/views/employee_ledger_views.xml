<odoo>
    <!-- List view -->
    <record id="view_hr_employee_ledger_move_list" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list string="Movimientos">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="concept"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_hr_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento">
                <header>
                    <button name="action_print_receipt" type="object" string="Imprimir recibo" class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="employee_id" options="{'no_create': True}"/>
                        <field name="type"/>
                        <field name="direction"/>
                        <field name="amount"/>
                        <field name="currency_id" readonly="1"/>
                        <field name="concept" placeholder="Detalle del anticipo o descuento"/>
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view (RNG-valid: fields first, then filters; no nested groups) -->
    <record id="view_hr_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search string="Buscar movimientos">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="type"/>
                <filter string="A (Dinero)" name="filter_type_a" domain="[('type','=','a')]"/>
                <filter string="B (Alimentos)" name="filter_type_b" domain="[('type','=','b')]"/>
                <filter string="Pagos al empleado" name="filter_dir_to" domain="[('direction','=','to_employee')]"/>
                <filter string="Descuentos / Devoluciones" name="filter_dir_from" domain="[('direction','=','from_employee')]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_hr_employee_ledger_moves" model="ir.actions.act_window">
        <field name="name">Movimientos</field>
        <field name="res_model">hr.employee.ledger.move</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_employee_id': active_id if active_model == 'hr.employee' else False}</field>
    </record>

    <!-- Smart button and notebook tab in hr.employee -->
    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_employee_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="%(action_hr_employee_ledger_moves)d" class="oe_stat_button" type="action" string="">
                    <div class="o_stat_info">
                        <field name="ledger_move_count" widget="statinfo" string="Nº Movimientos"/>
                    </div>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <field name="ledger_move_ids" context="{'default_employee_id': active_id}" nolabel="1">
                        <tree editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>