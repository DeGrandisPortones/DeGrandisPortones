<odoo>
    <data>

        <!-- List View -->
        <record id="view_employee_ledger_move_list" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.list</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <list string="Movimientos">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="type"/>
                    <field name="direction"/>
                    <field name="concept"/>
                    <field name="amount"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_employee_ledger_move_form" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.form</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <form string="Movimiento Cuenta Corriente">
                    <header>
                        <button name="%(action_employee_ledger_move_receipt)d"
                                type="action"
                                class="btn-primary"
                                string="Imprimir recibo"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="date"/>
                                <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            </group>
                            <group>
                                <field name="type"/>
                                <field name="direction"/>
                                <field name="amount"/>
                            </group>
                        </group>
                        <group>
                            <field name="concept" colspan="4"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_employee_ledger_move_search" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.search</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <search string="Buscar movimientos">
                    <field name="employee_id"/>
                    <field name="concept"/>
                    <filter name="filter_money" string="Dinero" domain="[('type','=','money')]"/>
                    <filter name="filter_food" string="Alimentos" domain="[('type','=','food')]"/>
                    <filter name="filter_out" string="Entregas" domain="[('direction','=','out')]"/>
                    <filter name="filter_in" string="Descuentos" domain="[('direction','=','in')]"/>
                </search>
            </field>
        </record>

        <!-- Action default views order -->
        <record id="action_hr_employee_ledger_moves_views" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">list</field>
            <field name="view_id" ref="view_employee_ledger_move_list"/>
            <field name="act_window_id" ref="action_hr_employee_ledger_moves"/>
        </record>
        <record id="action_hr_employee_ledger_moves_views_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="view_employee_ledger_move_form"/>
            <field name="act_window_id" ref="action_hr_employee_ledger_moves"/>
        </record>

        <!-- Inherit Employee Form -->
        <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
            <field name="name">hr.employee.form.ledger</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.view_employee_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/header" position="inside">
                    <button name="%(action_hr_employee_ledger_moves)d" class="oe_stat_button" type="action" string="">
                        <div class="o_stat_info">
                            <field name="ledger_move_count" widget="statinfo" string="Movs CC"/>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Cuenta Corriente">
                        <group>
                            <field name="ledger_balance" readonly="1"/>
                        </group>
                        <field name="ledger_move_ids" context="{'default_employee_id': active_id}" nolabel="1">
                            <list editable="bottom">
                                <field name="date"/>
                                <field name="type"/>
                                <field name="direction"/>
                                <field name="concept"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>

    </data>
</odoo>