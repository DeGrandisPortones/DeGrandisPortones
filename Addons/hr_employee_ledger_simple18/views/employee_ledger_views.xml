<odoo>
    <!-- Action -->
    <record id="action_hr_employee_ledger_moves" model="ir.actions.act_window">
        <field name="name">Movimientos</field>
        <field name="res_model">hr.employee.ledger.move</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="context">{}</field>
        <field name="search_view_id" ref="view_hr_employee_ledger_move_search"/>
    </record>

    <!-- Menu -->
    <menuitem id="menu_hr_employee_ledger_root" name="Ctas Ctes Empleados" parent="hr.menu_hr_root" sequence="70"/>
    <menuitem id="menu_hr_employee_ledger_moves" name="Movimientos" parent="menu_hr_employee_ledger_root" action="action_hr_employee_ledger_moves" sequence="10"/>

    <!-- Search -->
    <record id="view_hr_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="move_kind"/>
                <field name="direction"/>
                <filter string="Este mes" name="this_month" domain="[('date','&gt;=', context_today().replace(day=1)), ('date','&lt;', (context_today() + relativedelta(months=1)).replace(day=1))]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Empleado" name="group_employee" context="{'group_by':'employee_id'}"/>
                    <filter string="Tipo (A/B)" name="group_kind" context="{'group_by':'move_kind'}"/>
                    <filter string="Dirección" name="group_direction" context="{'group_by':'direction'}"/>
                    <filter string="Fecha" name="group_date" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Tree (List) -->
    <record id="view_hr_employee_ledger_move_list" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list string="Movimientos de empleados" create="1" edit="1">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="move_kind"/>
                <field name="direction"/>
                <field name="concept"/>
                <field name="amount" sum="Total"/>
            </list>
        </field>
    </record>

    <!-- Form -->
    <record id="view_hr_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento">
                <header>
                    <button name="%(action_report_hr_employee_ledger_receipt)d" string="Imprimir recibo" type="action" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="employee_id" options="{'no_open': False}"/>
                            <field name="move_kind"/>
                            <field name="direction"/>
                        </group>
                        <group>
                            <field name="currency_id"/>
                            <field name="amount"/>
                            <field name="concept"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Notas internas..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>