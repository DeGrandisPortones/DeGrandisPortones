<odoo>
    <data>
        <!-- Tree/List view -->
        <record id="view_hr_employee_ledger_move_list" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.list</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <list create="1" edit="1">
                    <field name="name"/>
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="move_type"/>
                    <field name="direction"/>
                    <field name="concept"/>
                    <field name="amount"/>
                </list>
            </field>
        </record>

        <!-- Search view -->
        <record id="view_hr_employee_ledger_move_search" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.search</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="move_type"/>
                    <field name="direction"/>
                    <filter string="Este año" name="this_year" domain="[('date','&gt;=', (context_today().replace(month=1, day=1))), ('date','&lt;=', context_today())]"/>
                    <group expand="0" string="Agrupar por">
                        <filter string="Empleado" name="grp_emp" context="{'group_by':'employee_id'}"/>
                        <filter string="Tipo A/B" name="grp_type" context="{'group_by':'move_type'}"/>
                        <filter string="Dirección" name="grp_dir" context="{'group_by':'direction'}"/>
                        <filter string="Fecha" name="grp_date" context="{'group_by':'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Form view -->
        <record id="view_hr_employee_ledger_move_form" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.form</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <form string="Movimiento de empleado">
                    <header>
                        <button name="action_print_receipt" type="object" class="oe_highlight" string="Imprimir recibo"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="date"/>
                                <field name="employee_id" options="{'no_create_edit': True}"/>
                                <field name="move_type"/>
                                <field name="direction"/>
                            </group>
                            <group>
                                <field name="concept"/>
                                <field name="amount"/>
                                <field name="signed_amount" readonly="1"/>
                                <field name="currency_id" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Employee extension: smart button + fields -->
        <record id="view_hr_employee_form_inherit_ledger" model="ir.ui.view">
            <field name="name">hr.employee.form.inherit.ledger</field>
            <field name="model">hr.employee</field>
            <field name="inherit_id" ref="hr.hr_employee_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet//div[@class='oe_button_box']" position="inside">
                    <button name="action_open_ledger_moves" type="object" class="oe_stat_button" icon="fa-list-alt">
                        <field name="ledger_move_count" widget="statinfo" string="Nº Movimientos"/>
                    </button>
                </xpath>
                <xpath expr="//sheet//group" position="inside">
                    <group string="Cuenta Corriente">
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>