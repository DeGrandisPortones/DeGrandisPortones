<odoo>
    <!-- Ledger Move views -->
    <record id="view_employee_ledger_move_tree" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="amount"/>
                <field name="concept"/>
            </list>
        </field>
    </record>

    <record id="view_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento Cuenta Corriente">
                <header>
                    <button name="action_print_receipt" type="object" class="btn-primary" string="Imprimir recibo"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="concept" colspan="4"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="date"/>
                <filter name="type_a" string="Tipo A (Dinero)" domain="[('type','=','a')]"/>
                <filter name="type_b" string="Tipo B (Alimentos)" domain="[('type','=','b')]"/>
                <filter name="dir_out" string="Adelantos" domain="[('direction','=','out')]"/>
                <filter name="dir_in" string="Descuentos" domain="[('direction','=','in')]"/>
            </search>
        </field>
    </record>

    <!-- Inherit Employee form -->
    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="%(action_employee_ledger_moves)d" class="oe_stat_button" type="action" string="">
                    <div class="o_stat_info">
                        <field name="ledger_move_count" widget="statinfo" string="Nº Movs"/>
                    </div>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <!-- No usar active_id en el contexto para evitar inconsistencias -->
                    <field name="ledger_move_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
