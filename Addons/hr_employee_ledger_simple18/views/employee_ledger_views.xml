<odoo>
    <!-- Search view for moves -->
    <record id="hr_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search string="Buscar movimientos">
                <field name="employee_id"/>
                <field name="concept"/>
                <filter string="Dinero (A)" name="type_a" domain="[('type','=','a')]"/>
                <filter string="Alimentos (B)" name="type_b" domain="[('type','=','b')]"/>
                <filter string="Debe (paga empresa)" name="dir_debit" domain="[('direction','=','debit')]"/>
                <filter string="Haber (devuelve empleado)" name="dir_credit" domain="[('direction','=','credit')]"/>
                <filter string="Hoy" name="today" domain="[('date','=', context_today())]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Empleado" context="{'group_by':'employee_id'}"/>
                    <filter string="Tipo" context="{'group_by':'type'}"/>
                    <filter string="Dirección" context="{'group_by':'direction'}"/>
                    <filter string="Fecha" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- List view for moves -->
    <record id="view_employee_ledger_move_list" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list string="Movimientos">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <!-- Form view for moves -->
    <record id="view_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento Cuenta Corriente">
                <header>
                    <button name="action_print_receipt" type="object" class="btn-primary" string="Imprimir recibo"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="concept" colspan="4"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action uses our list/form/search -->
    <record id="action_employee_ledger_moves_views" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_employee_ledger_move_list"/>
        <field name="act_window_id" ref="action_employee_ledger_moves"/>
    </record>
    <record id="action_employee_ledger_moves_views_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_employee_ledger_move_form"/>
        <field name="act_window_id" ref="action_employee_ledger_moves"/>
    </record>
    <record id="action_employee_ledger_moves_views_search" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">search</field>
        <field name="view_id" ref="hr_employee_ledger_move_search"/>
        <field name="act_window_id" ref="action_employee_ledger_moves"/>
    </record>

    <!-- Employee form inheritance -->
    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_open_employee_ledger_moves" class="oe_stat_button" type="object" string="">
                    <div class="o_stat_info">
                        <field name="ledger_move_count" widget="statinfo" string="Movimientos"/>
                    </div>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <field name="ledger_move_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>