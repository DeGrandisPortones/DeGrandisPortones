
<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Ledger Move Views -->
    <record id="view_employee_ledger_move_list" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list string="Movimientos">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="amount"/>
                <field name="concept"/>
            </list>
        </field>
    </record>

    <record id="view_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento Cuenta Corriente">
                <header>
                    <button name="action_print_receipt" type="object" class="btn-primary" string="Imprimir recibo"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="concept" colspan="4"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search string="Buscar Movimientos">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="date"/>
                <filter name="in" string="Ingresos" domain="[('direction','=','in')]"/>
                <filter name="out" string="Egresos" domain="[('direction','=','out')]"/>
                <filter name="type_a" string="Tipo A" domain="[('type','=','a')]"/>
                <filter name="type_b" string="Tipo B" domain="[('type','=','b')]"/>
            </search>
        </field>
    </record>

    <!-- Bind search + views to action -->
    <record id="action_employee_ledger_moves_views" model="ir.actions.act_window.view">
        <field name="sequence" eval="10"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_employee_ledger_move_list"/>
        <field name="act_window_id" ref="action_employee_ledger_moves"/>
    </record>

    <record id="action_employee_ledger_moves_views_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_employee_ledger_move_form"/>
        <field name="act_window_id" ref="action_employee_ledger_moves"/>
    </record>

    <record id="action_employee_ledger_moves_search" model="ir.actions.act_window">
        <field name="name">Movimientos</field>
        <field name="res_model">hr.employee.ledger.move</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_employee_ledger_move_search"/>
        <field name="context">{}</field>
    </record>

    <!-- Inherit Employee Form: stat button + page -->
    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_open_employee_ledger_moves" class="oe_stat_button" type="object" string="">
                    <div class="o_stat_info">
                        <field name="ledger_move_count" widget="statinfo" string="Movimientos"/>
                    </div>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <field name="ledger_move_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
