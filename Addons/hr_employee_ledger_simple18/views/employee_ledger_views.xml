<odoo>
    <data>
        <!-- Search view to allow defaulting by employee -->
        <record id="view_employee_ledger_move_search" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.search</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <search>
                    <field name="employee_id"/>
                    <field name="date"/>
                    <filter name="group_employee" string="Empleado" context="{'group_by': 'employee_id'}"/>
                </search>
            </field>
        </record>

        <!-- Tree/Form for the ledger moves -->
        <record id="view_employee_ledger_move_tree" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.tree</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="date"/>
                    <field name="employee_id"/>
                    <field name="type"/>
                    <field name="direction"/>
                    <field name="amount"/>
                </tree>
            </field>
        </record>

        <record id="view_employee_ledger_move_form" model="ir.ui.view">
            <field name="name">hr.employee.ledger.move.form</field>
            <field name="model">hr.employee.ledger.move</field>
            <field name="arch" type="xml">
                <form string="Movimiento Cuenta Corriente">
                    <header>
                        <button name="action_print_receipt" type="object" class="btn-primary" string="Imprimir recibo"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name" readonly="1"/>
                                <field name="date"/>
                                <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                            </group>
                            <group>
                                <field name="type"/>
                                <field name="direction"/>
                                <field name="amount"/>
                            </group>
                        </group>
                        <group>
                            <field name="concept" colspan="4"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Inherit HR Employee form: add stat button + new page -->
        <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
            <field name="name">hr.employee.form.ledger</field>
            <field name="model">hr.employee</field>
            <!-- Try the common xmlid first (Odoo 16/17). If it differs in 18, adjust in your DB by replacing with the actual view xmlid. -->
            <field name="inherit_id" ref="hr.hr_employee_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form/header" position="inside">
                    <button name="%(action_employee_ledger_moves)d" type="action" class="oe_stat_button" string="" context="{'search_default_employee_id': id}">
                        <div class="o_stat_info">
                            <field name="ledger_move_count" widget="statinfo" string="Nº Movimientos"/>
                        </div>
                    </button>
                </xpath>
                <xpath expr="//form/sheet/notebook" position="inside">
                    <page string="Cuenta Corriente">
                        <group>
                            <field name="ledger_balance" readonly="1"/>
                        </group>
                        <field name="ledger_move_ids" nolabel="1" context="{'default_employee_id': id}">
                            <tree editable="bottom">
                                <field name="date"/>
                                <field name="type"/>
                                <field name="direction"/>
                                <field name="concept"/>
                                <field name="amount"/>
                            </tree>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
