<odoo>
    <!-- Action & Views -->
    <record id="action_hr_employee_ledger_moves" model="ir.actions.act_window">
        <field name="name">Movimientos CC</field>
        <field name="res_model">hr.employee.ledger.move</field>
        <field name="view_mode">list,form,search</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p>Registre anticipos (A) y alimentos (B) de empleados, y obtenga el recibo.</p>
        </field>
    </record>

    <menuitem id="menu_hr_employee_ledger_root" name="Cuenta Corriente Empleados" sequence="50"/>
    <menuitem id="menu_hr_employee_ledger_moves" name="Movimientos" parent="menu_hr_employee_ledger_root" action="action_hr_employee_ledger_moves" sequence="10"/>

    <record id="hr_employee_ledger_move_list" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="concept"/>
                <field name="amount"/>
            </list>
        </field>
    </record>

    <record id="hr_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento CC">
                <header>
                    <button name="%(action_hr_employee_ledger_receipt)d" type="action" class="oe_highlight"
                            string="Imprimir recibo"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="date"/>
                        <field name="employee_id" options="{'no_quick_create': True}"/>
                        <field name="type"/>
                        <field name="direction"/>
                        <field name="concept"/>
                        <field name="amount"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="concept"/>
                <filter string="Hoy" name="today" domain="[('date', '=', context_today())]"/>
                <filter string="Tipo A" name="type_a" domain="[('type', '=', 'a')]"/>
                <filter string="Tipo B" name="type_b" domain="[('type', '=', 'b')]"/>
                <filter string="Pagos" name="dir_in" domain="[('direction', '=', 'in')]"/>
                <filter string="Descuentos" name="dir_out" domain="[('direction', '=', 'out')]"/>
            </search>
        </field>
    </record>

    <!-- Inherit Employee Form: use Odoo 18 view xmlid -->
    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="%(action_hr_employee_ledger_moves)d" class="oe_stat_button" type="action" string="">
                    <div class="o_stat_info">
                        <field name="ledger_move_count" widget="statinfo" string="Nº Movs"/>
                    </div>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <field name="ledger_move_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>