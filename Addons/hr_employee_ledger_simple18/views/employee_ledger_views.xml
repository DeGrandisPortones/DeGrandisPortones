
<odoo>
    <record id="action_employee_ledger_moves" model="ir.actions.act_window">
        <field name="name">Movimientos</field>
        <field name="res_model">hr.employee.ledger.move</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p>Registre adelantos (A/B) y deducciones de empleados.</p>
        </field>
    </record>

    <record id="view_employee_ledger_move_list" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.list</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <list string="Movimientos">
                <field name="name"/>
                <field name="date"/>
                <field name="employee_id"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="amount"/>
                <field name="concept"/>
            </list>
        </field>
    </record>

    <record id="view_employee_ledger_move_form" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.form</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <form string="Movimiento Cuenta Corriente">
                <header>
                    <button name="action_print_receipt" type="object" class="btn-primary" string="Imprimir recibo"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="amount"/>
                        </group>
                    </group>
                    <group>
                        <field name="concept" colspan="4"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_employee_ledger_move_search" model="ir.ui.view">
        <field name="name">hr.employee.ledger.move.search</field>
        <field name="model">hr.employee.ledger.move</field>
        <field name="arch" type="xml">
            <search string="Buscar movimientos">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="date"/>
                <filter name="type_a" string="Tipo A" domain="[('type','=','a')]"/>
                <filter name="type_b" string="Tipo B" domain="[('type','=','b')]"/>
                <filter name="dir_in" string="Ingreso" domain="[('direction','=','in')]"/>
                <filter name="dir_out" string="Entrega" domain="[('direction','=','out')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="grp_employee" string="Empleado" context="{'group_by':'employee_id'}"/>
                    <filter name="grp_type" string="Tipo" context="{'group_by':'type'}"/>
                    <filter name="grp_direction" string="Movimiento" context="{'group_by':'direction'}"/>
                    <filter name="grp_date" string="Fecha" context="{'group_by':'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="%(action_employee_ledger_moves)d" class="oe_stat_button" type="action" string="">
                    <div class="o_stat_info">
                        <field name="ledger_move_count" widget="statinfo" string="Nº Movimientos"/>
                    </div>
                </button>
            </xpath>
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <field name="ledger_move_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="date"/>
                            <field name="type"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
