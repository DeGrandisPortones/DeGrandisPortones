<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <!-- LIST (standalone). Root must be <list>, not <tree> in Odoo 18 -->
    <record id="view_employee_ledger_move_tree" model="ir.ui.view">
      <field name="name">hr.employee.ledger.move.list</field>
      <field name="model">hr.employee.ledger.move</field>
      <field name="arch" type="xml">
        <list string="Movimientos">
          <field name="name"/>
          <field name="date"/>
          <field name="employee_id"/>
          <field name="type"/>
          <field name="direction"/>
          <field name="amount"/>
        </list>
      </field>
    </record>

    <record id="view_employee_ledger_move_form" model="ir.ui.view">
      <field name="name">hr.employee.ledger.move.form</field>
      <field name="model">hr.employee.ledger.move</field>
      <field name="arch" type="xml">
        <form string="Movimiento Cuenta Corriente">
          <header>
            <button name="action_print_receipt" type="object" class="btn-primary" string="Imprimir recibo"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="name" readonly="1"/>
                <field name="date"/>
                <field name="employee_id" options="{'no_quick_create': True, 'no_create_edit': True}"/>
              </group>
              <group>
                <field name="type"/>
                <field name="direction"/>
                <field name="amount"/>
              </group>
            </group>
            <group>
              <field name="concept" colspan="4"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_employee_ledger_move_search" model="ir.ui.view">
      <field name="name">hr.employee.ledger.move.search</field>
      <field name="model">hr.employee.ledger.move</field>
      <field name="arch" type="xml">
        <search>
          <field name="employee_id" filter_domain="[('employee_id','=',self)]"/>
          <field name="type"/>
          <field name="direction"/>
          <field name="date"/>
          <filter name="mine" string="Del empleado" domain="[('employee_id','=',context.get('search_default_employee_id'))]"/>
        </search>
      </field>
    </record>

    <!-- Inherit Employee form to add stat button + tab -->
    <record id="hr_employee_form_inherit_ledger" model="ir.ui.view">
      <field name="name">hr.employee.form.ledger</field>
      <field name="model">hr.employee</field>
      <field name="inherit_id" ref="hr.hr_employee_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//form/header" position="inside">
          <button name="%(action_employee_ledger_moves)d"
                  type="action"
                  class="oe_stat_button"
                  string=""
                  context="{'search_default_employee_id': id}">
            <div class="o_stat_info">
              <field name="ledger_move_count" widget="statinfo" string="Nº Movimientos"/>
            </div>
          </button>
        </xpath>

        <xpath expr="//form/sheet/notebook" position="inside">
          <page string="Cuenta Corriente">
            <group>
              <field name="ledger_balance" readonly="1"/>
            </group>
            <field name="ledger_move_ids" context="{'default_employee_id': id}" nolabel="1">
              <list editable="bottom">
                <field name="date"/>
                <field name="type"/>
                <field name="direction"/>
                <field name="concept"/>
                <field name="amount"/>
              </list>
            </field>
          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
