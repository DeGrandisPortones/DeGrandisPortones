<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Add columns to employee list for quick balance view -->
    <record id="view_hr_employee_tree_ledger_inherit" model="ir.ui.view">
        <field name="name">hr.employee.tree.ledger.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_employee_view_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//tree" position="inside">
                <field name="ledger_balance"/>
            </xpath>
        </field>
    </record>

    <!-- Smart button and tab on employee form -->
    <record id="view_hr_employee_form_ledger_inherit" model="ir.ui.view">
        <field name="name">hr.employee.form.ledger.inherit</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.hr_employee_public_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_ledger_moves" type="object" class="oe_stat_button" icon="fa-list" string="Cuenta Corriente"/>
                <field name="ledger_balance" class="oe_stat_text" readonly="1"/>
            </xpath>
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Cuenta Corriente">
                    <group>
                        <field name="ledger_balance" readonly="1"/>
                    </group>
                    <field name="ledger_move_ids" context="{'default_employee_id': active_id}" readonly="0">
                        <tree editable="bottom">
                            <field name="name" readonly="1"/>
                            <field name="date"/>
                            <field name="move_kind"/>
                            <field name="direction"/>
                            <field name="concept"/>
                            <field name="amount"/>
                        </tree>
                        <form>
                            <sheet>
                                <group>
                                    <group>
                                        <field name="name" readonly="1"/>
                                        <field name="date"/>
                                        <field name="move_kind"/>
                                        <field name="direction"/>
                                    </group>
                                    <group>
                                        <field name="concept"/>
                                        <field name="amount"/>
                                    </group>
                                </group>
                                <group>
                                    <field name="note"/>
                                </group>
                            </sheet>
                        </form>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
