<odoo>
    <template id="employee_ledger_move_receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Recibo de Movimiento</h2>
                        <p><strong>Número:</strong> <span t-esc="o.name"/></p>
                        <p><strong>Fecha:</strong> <span t-esc="o.date"/></p>
                        <p><strong>Empleado:</strong> <span t-esc="o.employee_id.name"/></p>
                        <p><strong>Tipo:</strong> <span t-esc="o.type"/></p>
                        <p><strong>Dirección:</strong> <span t-esc="o.direction"/></p>
                        <p><strong>Monto:</strong> <span t-esc="o.amount"/> <span t-esc="o.currency_id.symbol"/></p>
                        <p><strong>Concepto:</strong> <span t-esc="o.concept"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
