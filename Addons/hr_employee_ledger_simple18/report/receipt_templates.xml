<odoo>
    <template id="report_employee_ledger_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 style="text-align:center">Recibo de anticipo / descuento</h2>
                        <p><strong>Empresa:</strong> <span t-field="doc.company_id.name"/></p>
                        <p><strong>Fecha:</strong> <span t-esc="doc.date"/></p>
                        <p><strong>Empleado:</strong> <span t-field="doc.employee_id.name"/></p>
                        <p><strong>Tipo:</strong>
                            <t t-if="doc.type == 'a'">A (Dinero)</t>
                            <t t-if="doc.type == 'b'">B (Alimentos)</t>
                        </p>
                        <p><strong>Dirección:</strong>
                            <t t-if="doc.direction == 'to_employee'">Pago al empleado</t>
                            <t t-if="doc.direction == 'from_employee'">Descuento/Devolución</t>
                        </p>
                        <p><strong>Concepto:</strong> <span t-esc="doc.concept"/></p>
                        <p><strong>Importe:</strong> <span t-esc="doc.amount"/> <span t-esc="doc.currency_id.symbol"/></p>
                        <br/><br/>
                        <table style="width:100%;margin-top:60px">
                            <tr>
                                <td style="width:50%;text-align:center;padding-top:60px;border-top:1px solid #000">Firma empleado</td>
                                <td style="width:50%;text-align:center;padding-top:60px;border-top:1px solid #000">Firma empresa</td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>