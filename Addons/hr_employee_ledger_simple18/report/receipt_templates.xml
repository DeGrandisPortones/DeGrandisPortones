<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <template id="employee_ledger_move_receipt">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <main class="o_report_layout_boxed">
            <div class="page">
              <h2>Recibo de Movimiento</h2>
              <p><strong>Número:</strong> <span t-esc="o.name"/></p>
              <p><strong>Fecha:</strong> <span t-esc="o.date"/></p>
              <p><strong>Empleado:</strong> <span t-esc="o.employee_id.name"/></p>
              <p><strong>Tipo:</strong> <span t-esc="o.type"/></p>
              <p><strong>Dirección:</strong> <span t-esc="o.direction"/></p>
              <p><strong>Importe:</strong> <span t-esc="o.amount"/> <span t-esc="o.currency_id.symbol"/></p>
              <p><strong>Concepto:</strong></p>
              <div t-esc="o.concept"/>
            </div>
          </main>
        </t>
      </t>
    </template>
  </data>
</odoo>
