<odoo>
    <template id="receipt_template">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc"/>
            <div class="page">
                <h2 style="text-align:center;">Recibo de Anticipo / Cuenta Corriente</h2>
                <p><strong>Compañía:</strong> <t t-esc="doc.company_id.name"/></p>
                <p><strong>Fecha:</strong> <t t-esc="doc.date"/></p>
                <p><strong>Número:</strong> <t t-esc="doc.name"/></p>
                <p><strong>Empleado:</strong> <t t-esc="doc.employee_id.name"/></p>
                <p><strong>Tipo:</strong> <t t-esc="dict(a='A - Dinero', b='B - Alimentos')[doc.type]"/></p>
                <p><strong>Dirección:</strong> <t t-esc="dict(**{'in':'Pago al empleado','out':'Descuento / Devolución'})[doc.direction]"/></p>
                <p><strong>Concepto:</strong> <t t-esc="doc.concept"/></p>
                <p><strong>Importe:</strong> <span t-field="doc.amount"/></p>

                <br/>
                <p><strong>Observaciones:</strong></p>
                <div style="min-height: 80px; border: 1px solid #999;"></div>

                <br/><br/>
                <table style="width:100%;">
                    <tr>
                        <td style="width:50%; text-align:center;">
                            ________________________________<br/>
                            Firma del Responsable
                        </td>
                        <td style="width:50%; text-align:center;">
                            ________________________________<br/>
                            Firma del Empleado
                        </td>
                    </tr>
                </table>
            </div>
        </t>
    </template>
</odoo>