<odoo>
  <template id="report_employee_ledger_move_receipt">
    <t t-call="web.external_layout">
      <div class="page">
        <h2 style="text-align:center; margin-bottom:10px;">Recibo de Anticipo / Movimiento</h2>
        <div>
          <strong>Empresa:</strong> <span t-esc="o.employee_id.company_id.name"/>
        </div>
        <div>
          <strong>Fecha:</strong> <span t-esc="o.date"/>
        </div>
        <div>
          <strong>Empleado:</strong> <span t-esc="o.employee_id.name"/>
        </div>
        <div>
          <strong>Referencia:</strong> <span t-esc="o.name"/>
        </div>
        <div>
          <strong>Tipo:</strong> <span t-esc="dict(o._fields['type'].selection).get(o.type)"/>
        </div>
        <div>
          <strong>Movimiento:</strong> <span t-esc="dict(o._fields['direction'].selection).get(o.direction)"/>
        </div>
        <div>
          <strong>Concepto:</strong> <span t-esc="o.concept"/>
        </div>
        <div style="margin-top:10px; font-size:16px;">
          <strong>Importe:</strong>
          <span t-esc="o.amount"/>&nbsp;<span t-esc="o.currency_id.symbol"/>
        </div>

        <div style="margin-top:40px;">
          <div style="width:45%; display:inline-block; text-align:center;">
            ___________________________<br/>
            Firma del Empleado
          </div>
          <div style="width:9%; display:inline-block;">&nbsp;</div>
          <div style="width:45%; display:inline-block; text-align:center;">
            ___________________________<br/>
            Autorización RRHH
          </div>
        </div>
      </div>
    </t>
  </template>
</odoo>