<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="employee_ledger_move_receipt">
    <t t-call="web.external_layout">
      <main class="o_report_layout">
        <div class="page">
          <h2>Recibo de Movimiento</h2>
          <p><strong>Movimiento:</strong> <span t-esc="doc.name"/></p>
          <p><strong>Fecha:</strong> <span t-esc="doc.date"/></p>
          <p><strong>Empleado:</strong> <span t-esc="doc.employee_id.name"/></p>
          <p><strong>Tipo:</strong>
            <span t-esc="dict(doc._fields['type'].selection).get(doc.type)"/>
          </p>
          <p><strong>Dirección:</strong>
            <span t-esc="dict(doc._fields['direction'].selection).get(doc.direction)"/>
          </p>
          <p><strong>Importe:</strong> <span t-esc="doc.amount"/> <span t-esc="doc.currency_id.symbol"/></p>
          <p><strong>Concepto:</strong> <span t-esc="doc.concept"/></p>
        </div>
      </main>
    </t>
  </template>
</odoo>