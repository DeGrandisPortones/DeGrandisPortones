<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <template id="employee_ledger_move_receipt">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.external_layout">
          <main>
            <div class="page">

              <!-- Título -->
              <div style="text-align:center; margin-bottom:16px;">
                <h2 style="margin:0; text-transform:uppercase; font-size:18px;">
                  Recibo de haberes
                </h2>
              </div>

              <!-- Datos principales -->
              <div style="border:1px solid #000; border-radius:4px; padding:12px; font-size:11pt;">
                <table style="width:100%; border-collapse:collapse;">
                  <tr>
                    <td style="width:50%;">
                      <strong>Empleado:</strong>
                      <span t-esc="o.employee_id.name"/>
                    </td>
                    <td style="width:50%; text-align:right;">
                      <strong>Fecha:</strong>
                      <span t-esc="o.date"/>
                    </td>
                  </tr>
                  <tr>
                    <td>
                      <strong>Empresa:</strong>
                      <span t-esc="o.company_id.name"/>
                    </td>
                    <td style="text-align:right;">
                      <strong>Número:</strong>
                      <span t-esc="o.name"/>
                    </td>
                  </tr>
                </table>

                <!-- Concepto e importe -->
                <table style="width:100%; border-collapse:collapse; margin-top:14px;">
                  <tr>
                    <th style="text-align:left; border-bottom:1px solid #000; padding:4px 0;">
                      Concepto
                    </th>
                    <th style="text-align:right; border-bottom:1px solid #000; padding:4px 0;">
                      Importe
                    </th>
                  </tr>
                  <tr>
                    <td style="padding:4px 0;">
                      <span t-esc="o.concept"/>
                    </td>
                    <td style="padding:4px 0; text-align:right;">
                      <span t-esc="(o.currency_id.symbol or '$') + ' ' + ('%.2f' % o.amount)"/>
                    </td>
                  </tr>
                </table>

                <!-- Tipo de movimiento -->
                <p style="margin-top:12px;">
                  <strong>Tipo:</strong>
                  <span t-esc="dict(o.fields_get(['type'])['type']['selection']).get(o.type, o.type)"/>
                </p>

                <!-- Firma / Aclaración / DNI -->
                <div style="margin-top:32px;">
                  <table style="width:100%; text-align:center; font-size:9pt;">
                    <tr>
                      <td>______________________________</td>
                      <td>______________________________</td>
                      <td>______________________________</td>
                    </tr>
                    <tr>
                      <td>Firma</td>
                      <td>Aclaración</td>
                      <td>DNI</td>
                    </tr>
                  </table>
                </div>
              </div>

            </div>
          </main>
        </t>
      </t>
    </t>
  </template>
</odoo>
