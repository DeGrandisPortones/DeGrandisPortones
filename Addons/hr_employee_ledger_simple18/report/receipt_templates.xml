<odoo>
    <template id="employee_ledger_move_receipt" name="Employee Ledger Move - Receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Recibo de Movimiento</h2>
                        <p><strong>Empleado:</strong> <span t-esc="o.employee_id.display_name"/></p>
                        <p><strong>Fecha:</strong> <span t-esc="o.date"/></p>
                        <p><strong>Tipo:</strong> <span t-esc="o.type"/></p>
                        <p><strong>Dirección:</strong> <span t-esc="o.direction"/></p>
                        <p><strong>Monto:</strong>
                            <span t-esc="formatLang(o.amount, currency_obj=(o.currency_id or o.company_id.currency_id))"/>
                        </p>
                        <p><strong>Concepto:</strong> <span t-esc="o.concept"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
