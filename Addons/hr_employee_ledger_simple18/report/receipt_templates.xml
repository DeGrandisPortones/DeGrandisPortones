<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_employee_ledger_move_receipt">
        <t t-call="web.external_layout">
            <t t-set="doc" t-value="doc"/>
            <div class="page">
                <h2>Recibo de Movimiento</h2>
                <p><strong>Número:</strong> <t t-esc="doc.name"/></p>
                <p><strong>Fecha:</strong> <t t-esc="doc.date"/></p>
                <p><strong>Empleado:</strong> <t t-esc="doc.employee_id.name"/></p>
                <p><strong>Tipo:</strong> <t t-esc="dict(doc.fields_get(allfields=['type'])['type']['selection']).get(doc.type) if hasattr(doc, 'fields_get') else doc.type"/></p>
                <p><strong>Sentido:</strong> <t t-esc="dict(doc.fields_get(allfields=['direction'])['direction']['selection']).get(doc.direction) if hasattr(doc, 'fields_get') else doc.direction"/></p>
                <p><strong>Monto:</strong> <t t-esc="doc.currency_id.symbol"/> <t t-esc="doc.amount"/></p>
                <p><strong>Concepto:</strong></p>
                <p t-esc="doc.concept"/>
                <br/>
                <table class="table table-sm" style="margin-top:40px;">
                    <tr>
                        <td style="padding-top:60px;">______________________________<br/>Firma del Empleado</td>
                        <td style="padding-top:60px;">______________________________<br/>Aclaración</td>
                        <td style="padding-top:60px;">______________________________<br/>DNI</td>
                    </tr>
                </table>
            </div>
        </t>
    </template>
</odoo>
