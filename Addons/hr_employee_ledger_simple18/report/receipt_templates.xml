<odoo>
    <template id="employee_ledger_move_receipt">
        <t t-call="web.external_layout">
            <div class="page">
                <t t-foreach="docs" t-as="doc">
                    <h2>Recibo de Movimiento</h2>
                    <p><strong>Número:</strong> <span t-esc="doc.name"/></p>
                    <p><strong>Fecha:</strong> <span t-esc="doc.date"/></p>
                    <p><strong>Empleado:</strong> <span t-esc="doc.employee_id.display_name"/></p>
                    <p><strong>Tipo:</strong> <span t-esc="doc.type"/></p>
                    <p><strong>Dirección:</strong> <span t-esc="doc.direction"/></p>
                    <p><strong>Concepto:</strong> <span t-esc="doc.concept"/></p>
                    <p><strong>Importe:</strong> <span t-esc="doc.amount"/> <span t-esc="doc.currency_id.symbol"/></p>
                    <hr/>
                </t>
            </div>
        </t>
    </template>
</odoo>