<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_employee_ledger_move_receipt">
    <t t-call="web.html_container">
      <t t-call="web.external_layout">
        <div class="page">
          <h2 style="text-align:center;">Recibo de Movimiento de Cuenta Corriente</h2>
          <p><strong>Empresa:</strong> <span t-esc="res_company.display_name"/></p>
          <p><strong>Fecha:</strong> <span t-esc="o.date"/></p>
          <p><strong>Número:</strong> <span t-esc="o.name"/></p>
          <p><strong>Empleado:</strong> <span t-esc="o.employee_id.name"/></p>
          <p><strong>Tipo:</strong> <span t-esc="dict([('money','Anticipo Dinero (A)'),('food','Anticipo Alimentos (B)')]).get(o.type)"/></p>
          <p><strong>Sentido:</strong> <span t-esc="dict([('out','Entrega/Anticipo'),('in','Devolución/Descuento')]).get(o.direction)"/></p>
          <p><strong>Monto:</strong> <span t-esc="format_amount(o.amount, o.currency_id)"/></p>
          <p><strong>Concepto:</strong> <span t-esc="o.concept or ''"/></p>

          <div style="margin-top:40px;">
            <div style="width:45%; display:inline-block; text-align:center;">
              <div style="border-top:1px solid #000; padding-top:8px;">Firma Empleado</div>
            </div>
            <div style="width:9%; display:inline-block;">&nbsp;</div>
            <div style="width:45%; display:inline-block; text-align:center;">
              <div style="border-top:1px solid #000; padding-top:8px;">Firma y Sello Empresa</div>
            </div>
          </div>
        </div>
      </t>
    </t>
  </template>
</odoo>
