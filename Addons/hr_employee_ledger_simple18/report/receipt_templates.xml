<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="receipt_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-set="doc" t-value="o"/>
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Recibo de Movimiento</h2>
                        <p><strong>Número:</strong> <t t-esc="o.name"/></p>
                        <p><strong>Fecha:</strong> <t t-esc="o.date"/></p>
                        <p><strong>Empleado:</strong> <t t-esc="o.employee_id.name"/></p>
                        <p><strong>Tipo:</strong> <t t-esc="o.type"/></p>
                        <p><strong>Dirección:</strong> <t t-esc="o.direction"/></p>
                        <p><strong>Monto:</strong> <span t-field="o.amount" t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/></p>
                        <p><strong>Concepto:</strong> <t t-esc="o.concept"/></p>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
