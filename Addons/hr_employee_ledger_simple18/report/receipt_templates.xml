<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- QWeb template for the PDF receipt. 
       IMPORTANT: we removed any reference to 'direction' because the model does not define that field.
       We also render the selection label for 'type' in a safe way.
  -->
  <template id="employee_ledger_move_receipt">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.external_layout">
          <main>
            <div class="page">
              <h2>Recibo de Movimiento</h2>

              <p><strong>Nombre:</strong> <span t-esc="o.name"/></p>
              <p><strong>Fecha:</strong> <span t-esc="o.date"/></p>
              <p><strong>Empleado:</strong> <span t-esc="o.employee_id.name"/></p>

              <!-- Show selection label for 'type' (falls back to the raw value if not found) -->
              <p>
                <strong>Tipo:</strong>
                <span t-esc="dict(o.fields_get(['type'])['type']['selection']).get(o.type, o.type)"/>
              </p>

              <p><strong>Monto:</strong> <span t-esc="o.amount"/></p>
              <p><strong>Concepto:</strong> <span t-esc="o.concept"/></p>
            </div>
          </main>
        </t>
      </t>
    </t>
  </template>
</odoo>
