<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <template id="portal_my_home_inherit_presupuestador" inherit_id="portal.portal_my_home">
            <xpath expr="//div[contains(@class,'o_portal_docs')]" position="inside">
                <a class="o_portal_doc" href="/my/presupuestador" role="button">
                    <div class="o_portal_doc_icon">
                        <i class="fa fa-calculator"/>
                    </div>
                    <div class="o_portal_doc_info">
                        <span class="o_portal_doc_title">Presupuestador</span>
                        <small class="text-muted d-block">Crear y gestionar presupuestos</small>
                    </div>
                </a>
            </xpath>
        </template>

        <template id="portal_presupuestador_list" name="Presupuestador - Lista">
            <t t-call="portal.portal_layout">
                <t t-set="breadcrumbs_searchbar" t-value="True"/>
                <div class="container mt-3 mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="mb-0">Presupuestador</h2>

                        <form action="/my/presupuestador/create" method="post" class="d-flex gap-2">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div>
                                <label class="form-label mb-0 small">Coeficiente (%)</label>
                                <input class="form-control form-control-sm" type="number" step="0.01" name="coeficiente" value="25"/>
                            </div>
                            <div class="align-self-end">
                                <button class="btn btn-primary btn-sm" type="submit">Crear</button>
                            </div>
                        </form>
                    </div>

                    <div class="card">
                        <div class="card-body">
                            <t t-if="not pedidos">
                                <p class="mb-0">Aún no hay presupuestos. Creá el primero con el botón “Crear”.</p>
                            </t>
                            <t t-else="">
                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead>
                                            <tr>
                                                <th>Número</th>
                                                <th>Estado</th>
                                                <th>Cliente/Distribuidor</th>
                                                <th>Coef (%)</th>
                                                <th>Total</th>
                                                <th class="text-end">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-foreach="pedidos" t-as="p">
                                                <tr>
                                                    <td><t t-esc="p.name"/></td>
                                                    <td><t t-esc="dict(p._fields['state'].selection).get(p.state)"/></td>
                                                    <td><t t-esc="p.partner_id.display_name"/></td>
                                                    <td><t t-esc="p.coeficiente"/></td>
                                                    <td><t t-esc="p.amount_total"/> <t t-esc="p.currency_id.symbol"/></td>
                                                    <td class="text-end">
                                                        <a t-att-href="'/my/presupuestador/%s' % p.id" class="btn btn-outline-primary btn-sm">Abrir</a>
                                                        <a t-att-href="'/my/presupuestador/%s/print' % p.id" class="btn btn-outline-secondary btn-sm">PDF</a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </t>
        </template>

        <template id="portal_presupuestador_detail" name="Presupuestador - Detalle">
            <t t-call="portal.portal_layout">
                <div class="container mt-3 mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h2 class="mb-0"><t t-esc="pedido.name"/></h2>
                            <div class="text-muted small">
                                Cliente/Distribuidor: <t t-esc="pedido.partner_id.display_name"/>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/my/presupuestador" class="btn btn-outline-secondary btn-sm">Volver</a>
                            <a t-att-href="'/my/presupuestador/%s/print' % pedido.id" class="btn btn-secondary btn-sm">PDF</a>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-lg-5">
                            <div class="card">
                                <div class="card-header">Datos y medidas</div>
                                <div class="card-body">
                                    <form t-att-action="'/my/presupuestador/%s/update_header' % pedido.id" method="post" class="row g-2">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="col-12">
                                            <label class="form-label">Sistema</label>
                                            <input class="form-control" type="text" name="sistema" t-att-value="pedido.sistema or ''"/>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Ancho (m)</label>
                                            <input class="form-control" type="number" step="0.01" name="ancho" t-att-value="pedido.ancho"/>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Alto (m)</label>
                                            <input class="form-control" type="number" step="0.01" name="alto" t-att-value="pedido.alto"/>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Peso (kg/m²)</label>
                                            <input class="form-control" type="number" step="0.01" name="peso_m2" t-att-value="pedido.peso_m2"/>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Coeficiente (%)</label>
                                            <input class="form-control" type="number" step="0.01" name="coeficiente" t-att-value="pedido.coeficiente"/>
                                        </div>

                                        <div class="col-6">
                                            <label class="form-label">m² (calc.)</label>
                                            <input class="form-control" type="text" readonly="1" t-att-value="pedido.m2"/>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Peso total (kg)</label>
                                            <input class="form-control" type="text" readonly="1" t-att-value="pedido.peso_total"/>
                                        </div>

                                        <div class="col-12">
                                            <button class="btn btn-primary" type="submit">Guardar</button>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <div class="card mt-3">
                                <div class="card-header">Totales</div>
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <span>Subtotal</span>
                                        <strong><t t-esc="pedido.amount_untaxed"/> <t t-esc="pedido.currency_id.symbol"/></strong>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>IVA</span>
                                        <strong><t t-esc="pedido.amount_tax"/> <t t-esc="pedido.currency_id.symbol"/></strong>
                                    </div>
                                    <hr/>
                                    <div class="d-flex justify-content-between">
                                        <span>Total</span>
                                        <strong><t t-esc="pedido.amount_total"/> <t t-esc="pedido.currency_id.symbol"/></strong>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-7">
                            <div class="card">
                                <div class="card-header">Agregar ítem (por rubro)</div>
                                <div class="card-body">
                                    <form t-att-action="'/my/presupuestador/%s/add_line' % pedido.id" method="post" class="row g-2">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <div class="col-6">
                                            <label class="form-label">Rubro</label>
                                            <select class="form-select" name="rubro_id" required="1">
                                                <t t-foreach="rubros" t-as="r">
                                                    <option t-att-value="r.id"><t t-esc="r.name"/> (<t t-esc="dict(r._fields['qty_mode'].selection).get(r.qty_mode)"/>)</option>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="col-6">
                                            <label class="form-label">Producto</label>
                                            <select class="form-select" name="product_id" required="1">
                                                <t t-foreach="products" t-as="prod">
                                                    <option t-att-value="prod.id"><t t-esc="prod.display_name"/></option>
                                                </t>
                                            </select>
                                        </div>
                                        <div class="col-4">
                                            <label class="form-label">Cantidad (si rubro manual)</label>
                                            <input class="form-control" type="number" step="0.01" name="qty" value="1"/>
                                        </div>
                                        <div class="col-8">
                                            <label class="form-label">Observación</label>
                                            <input class="form-control" type="text" name="obs"/>
                                        </div>
                                        <div class="col-12">
                                            <button class="btn btn-success" type="submit">Agregar</button>
                                        </div>
                                    </form>

                                    <p class="text-muted small mt-2 mb-0">
                                        Nota: si el rubro es m² o 1 unidad, la cantidad se calcula automáticamente.
                                    </p>
                                </div>
                            </div>

                            <div class="card mt-3">
                                <div class="card-header">Detalle</div>
                                <div class="card-body">
                                    <t t-if="not pedido.line_ids">
                                        <p class="mb-0">Aún no hay ítems cargados.</p>
                                    </t>
                                    <t t-else="">
                                        <div class="table-responsive">
                                            <table class="table table-sm table-hover align-middle">
                                                <thead>
                                                    <tr>
                                                        <th>Rubro</th>
                                                        <th>Producto</th>
                                                        <th class="text-end">Cant.</th>
                                                        <th class="text-end">Precio Distr.</th>
                                                        <th class="text-end">Precio</th>
                                                        <th class="text-end">Total</th>
                                                        <th class="text-end"></th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <t t-foreach="pedido.line_ids" t-as="l">
                                                        <tr>
                                                            <td><t t-esc="l.rubro_id.name"/></td>
                                                            <td>
                                                                <div><t t-esc="l.product_id.display_name"/></div>
                                                                <t t-if="l.obs"><div class="text-muted small"><t t-esc="l.obs"/></div></t>
                                                            </td>
                                                            <td class="text-end"><t t-esc="l.qty"/></td>
                                                            <td class="text-end"><t t-esc="l.precio_distr"/></td>
                                                            <td class="text-end"><t t-esc="l.price_unit"/></td>
                                                            <td class="text-end"><t t-esc="l.price_total"/></td>
                                                            <td class="text-end">
                                                                <a t-att-href="'/my/presupuestador/%s/remove_line/%s' % (pedido.id, l.id)"
                                                                   class="btn btn-outline-danger btn-sm"
                                                                   onclick="return confirm('¿Eliminar ítem?');">Eliminar</a>
                                                            </td>
                                                        </tr>
                                                    </t>
                                                </tbody>
                                            </table>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </template>

    </data>
</odoo>
