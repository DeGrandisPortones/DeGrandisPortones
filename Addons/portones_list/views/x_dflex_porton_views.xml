<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_x_dflex_porton_list" model="ir.ui.view">
    <field name="name">x_dflex.porton.list</field>
    <field name="model">x_dflex.porton</field>
    <field name="arch" type="xml">
      <list string="Portones" editable="bottom" create="1" edit="1" delete="1">
        <field name="x_name" string="Nombre"/>
        <field name="x_nota_de_venta" string="Nota de Venta"/>
        <field name="x_nombre_del_cliente" string="Nombre del cliente"/>
        <field name="x_direccion_del_cliente" string="Dirección"/>
        <field name="x_distribuidor" string="Distribuidor"/>
        <field name="x_estado" string="Estado"/>
        <field name="x_fecha_de_pedido" string="Fecha de pedido"/>
        <field name="x_fecha_de_entrega" string="Fecha de entrega"/>
        <field name="x_fecha_de_entrega_estimada" string="Entrega estimada"/>
      </list>
    </field>
  </record>

  <record id="view_x_dflex_porton_form" model="ir.ui.view">
    <field name="name">x_dflex.porton.form</field>
    <field name="model">x_dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <group>
              <field name="x_name"/>
              <field name="x_nota_de_venta"/>
              <field name="x_distribuidor"/>
              <field name="x_nombre_del_cliente"/>
              <field name="x_direccion_del_cliente"/>
              <field name="x_estado"/>
            </group>
            <group>
              <field name="x_fecha_de_pedido"/>
              <field name="x_fecha_de_entrega"/>
              <field name="x_fecha_de_entrega_estimada"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_x_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">x_dflex.porton</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_portones_root" name="Portones" sequence="10"/>
  <menuitem id="menu_portones_list" name="Registros" parent="menu_portones_root" action="action_x_dflex_porton" sequence="10"/>
</odoo>
