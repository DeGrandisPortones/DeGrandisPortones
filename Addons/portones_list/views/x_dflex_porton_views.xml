<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- LISTA (editable inline) -->
    <record id="view_x_dflex_porton_list" model="ir.ui.view">
        <field name="name">x_dflex.porton.list</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <list string="Portones"
                  create="True" edit="True" delete="True"
                  editable="bottom">
                <!-- Campos EDITABLES -->
                <field name="x_name"                  string="Nombre"/>
                <field name="x_nombre_del_cliente"    string="Nombre del cliente"/>
                <field name="x_distribuidor"          string="Distribuidor"/>
                <field name="x_direccion_del_cliente" string="Dirección del cliente"/>
                <field name="x_nota_de_venta"         string="Nota de Venta"/>

                <!-- Info de sistema (SOLO LECTURA) -->
                <field name="display_name" string="Display Name" readonly="1"/>
                <field name="create_date"  string="Creado"       readonly="1"/>
                <field name="write_date"   string="Actualizado"  readonly="1"/>
                <field name="create_uid"   string="Created by"   readonly="1"/>
                <field name="write_uid"    string="Last Updated by" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- FORM (editable) -->
    <record id="view_x_dflex_porton_form" model="ir.ui.view">
        <field name="name">x_dflex.porton.form</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <form string="Portón" create="True" edit="True" delete="True">
                <sheet>
                    <group>
                        <group>
                            <field name="x_name"/>
                            <field name="x_nombre_del_cliente"/>
                            <field name="x_distribuidor"/>
                        </group>
                        <group>
                            <field name="x_direccion_del_cliente"/>
                            <field name="x_nota_de_venta"/>
                            <field name="display_name" readonly="1"/>
                            <field name="create_uid"   readonly="1"/>
                            <field name="write_uid"    readonly="1"/>
                            <field name="create_date"  readonly="1"/>
                            <field name="write_date"   readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_x_dflex_porton_search" model="ir.ui.view">
        <field name="name">x_dflex.porton.search</field>
        <field name="model">x_dflex.porton</field>
        <field name="arch" type="xml">
            <search string="Buscar Portones">
                <field name="x_name"/>
                <field name="x_nombre_del_cliente"/>
                <field name="x_distribuidor"/>
                <field name="x_direccion_del_cliente"/>
                <field name="x_nota_de_venta"/>
                <filter name="recent" string="Últimos 7 días"
                        domain="[('create_date','&gt;=', (context_today() - relativedelta(days=7)).strftime('%%Y-%%m-%%d'))]"/>
            </search>
        </field>
    </record>

    <!-- ACCIÓN + MENÚ -->
    <record id="action_x_dflex_porton" model="ir.actions.act_window">
        <field name="name">Portones</field>
        <field name="res_model">x_dflex.porton</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay registros aún.</p>
        </field>
    </record>

    <menuitem id="menu_portones_root"  name="Portones" sequence="10"/>
    <menuitem id="menu_portones_list"  name="Registros" parent="menu_portones_root"
              action="action_x_dflex_porton" sequence="10"/>
</odoo>
