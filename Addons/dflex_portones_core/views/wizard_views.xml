<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_dflex_bulk_fields_wizard" model="ir.ui.view">
    <field name="name">dflex.bulk.fields.wizard.form</field>
    <field name="model">dflex.bulk.fields.wizard</field>
    <field name="arch" type="xml">
      <form string="Crear campos desde encabezados CSV">
        <group>
          <label for="header_line" class="o_form_label"/>
          <field name="header_line" placeholder="Encabezado1, Encabezado2, ..."/>
          <field name="delimiter"/>
          <label class="o_form_label"
                 string="Pegá la PRIMERA FILA de tu CSV (sólo encabezados). Omito 'name' y 'Columna X'."/>
        </group>
        <footer>
          <button string="Crear campos" type="object" name="action_create_fields" class="btn-primary"/>
          <button string="Cancelar" class="btn-secondary" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>