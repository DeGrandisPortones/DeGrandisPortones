<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Menú raíz -->
  <menuitem id="menu_dflex_portones_root" name="Portones" sequence="10"/>

  <!-- Acción -->
  <record id="action_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">dflex.porton</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- Vista LISTA (antes era tree) -->
  <record id="view_dflex_porton_list" model="ir.ui.view">
    <field name="name">dflex.porton.list</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
      </list>
    </field>
  </record>

  <!-- Vista FORM mínima -->
  <record id="view_dflex_porton_form" model="ir.ui.view">
    <field name="name">dflex.porton.form</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <field name="name"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Menú que lanza la acción -->
  <menuitem id="menu_dflex_portones_list"
            name="Portones"
            parent="menu_dflex_portones_root"
            action="action_dflex_porton"
            sequence="20"/>
</odoo>
