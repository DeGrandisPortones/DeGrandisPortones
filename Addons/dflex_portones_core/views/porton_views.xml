<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- MENÚ RAÍZ (debe existir antes de los hijos) -->
  <menuitem id="menu_dflex_portones_root" name="Portones" sequence="10"/>

  <!-- ACCIÓN DE VENTANA -->
  <record id="action_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">dflex.porton</field>
    <field name="view_mode">tree,form</field>
  </record>

  <!-- VISTA LISTA -->
  <record id="view_dflex_porton_tree" model="ir.ui.view">
    <field name="name">dflex.porton.tree</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
      </tree>
    </field>
  </record>

  <!-- VISTA FORM (mínima para que cargue seguro) -->
  <record id="view_dflex_porton_form" model="ir.ui.view">
    <field name="name">dflex.porton.form</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <field name="name"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- MENÚ LISTA apuntando a la acción -->
  <menuitem id="menu_dflex_portones_list"
            name="Portones"
            parent="menu_dflex_portones_root"
            action="action_dflex_porton"
            sequence="20"/>
</odoo>
