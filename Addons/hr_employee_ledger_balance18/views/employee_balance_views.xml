<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <!-- LISTA GLOBAL (permite elegir empleado y crear pagos/cargos) -->
  <record id="view_employee_ledger_move_tree_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list create="1" edit="1">
        <field name="date"/>
        <field name="employee_id" required="1"/>
        <field name="type"/>
        <field name="concept"/>
        <field name="amount"/>
      </list>
    </field>
  </record>

  <!-- FORM PARA ALTA / EDICIÓN -->
  <record id="view_employee_ledger_move_form_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.form.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="date"/>
            <field name="employee_id" options="{'no_create_edit': False}"/>
            <field name="type"/>
            <field name="concept"/>
            <field name="amount"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- SEARCH VIEW con filtros útiles -->
  <record id="view_employee_ledger_move_search_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.search.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="employee_id"/>
        <field name="type"/>
        <filter string="Cargos" name="type_charge" domain="[('type','=','charge')]"/>
        <filter string="Pagos" name="type_payment" domain="[('type','=','payment')]"/>
        <filter string="Agrupar por empleado" name="group_employee" context="{'group_by': 'employee_id'}"/>
        <separator/>
        <field name="date"/>
      </search>
    </field>
  </record>

  <!-- ACCIÓN GLOBAL (sin context, permite elegir cualquier empleado) -->
  <record id="action_employee_ledger_balance" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_employee_ledger_move_search_balance"/>
    <field name="context">{}</field>
  </record>

  <!-- ACCIÓN CONTEXTUAL en Empleado (Action menu). NO poner context en botones de vista -->
  <record id="action_employee_ledger_balance_for_employee" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_employee_ledger_move_search_balance"/>
    <field name="context">{'search_default_employee_id': active_id, 'default_employee_id': active_id}</field>
    <field name="binding_model_id" ref="hr.model_hr_employee"/>
    <field name="binding_view_types">form</field>
  </record>
</odoo>