<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- List (root must be <list> in Odoo 18) -->
  <record id="view_employee_ledger_move_list_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list string="Cuenta Corriente" editable="bottom">
        <field name="date"/>
        <field name="employee_id" optional="hide"/>
        <field name="type"/>
        <field name="concept"/>
        <field name="amount"/>
      </list>
    </field>
  </record>

  <!-- Search -->
  <record id="view_employee_ledger_move_search_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.search.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <search string="Buscar Movimientos">
        <field name="employee_id"/>
        <filter name="today" string="Hoy" domain="[('date','=', context_today().date())]"/>
        <group expand="0" string="Agrupar por">
          <filter name="group_employee" string="Empleado" context="{'group_by': 'employee_id'}"/>
          <filter name="group_date" string="Fecha" context="{'group_by': 'date'}"/>
          <filter name="group_type" string="Tipo" context="{'group_by': 'type'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Action for MENU (no active_id in context) -->
  <record id="action_employee_ledger_balance_menu" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_employee_ledger_move_search_balance"/>
    <field name="target">current</field>
    <!-- no context with active_id here to avoid NameError -->
  </record>

  <!-- Action bound to hr.employee (Action menu on employee form) -->
  <record id="action_employee_ledger_balance" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_employee_ledger_move_search_balance"/>
    <field name="target">current</field>
    <field name="context">{'search_default_employee_id': active_id and [active_id] or [], 'default_employee_id': active_id or False}</field>
    <field name="binding_model_id" ref="hr.model_hr_employee"/>
    <field name="binding_view_types">form</field>
  </record>

  <!-- Menu under the root menu of the ledger module -->
  <menuitem id="menu_hr_employee_ledger_balance"
            name="Cuenta Corriente"
            parent="hr_employee_ledger_simple18.menu_hr_employee_ledger_root"
            action="action_employee_ledger_balance_menu"
            sequence="20"/>
</odoo>
