<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- LIST VIEW: Cuenta Corriente de Empleados -->
  <record id="view_employee_ledger_move_tree_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list string="Cuenta Corriente" create="false" edit="false">
        <field name="date"/>
        <field name="employee_id" optional="hide"/>
        <field name="type"/>
        <field name="concept"/>
        <field name="amount"/>
        <field name="receipt_sequence" invisible="1"/>
      </list>
    </field>
  </record>

  <!-- SEARCH VIEW: filtros y agrupaciones útiles -->
  <record id="view_employee_ledger_move_search_balance" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.search.balance</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <search string="Cuenta Corriente">
        <field name="employee_id"/>
        <filter name="today" string="Hoy" domain="[('date','=', context_today().date())]"/>
        <group expand="0" string="Agrupar por">
          <filter name="grp_employee" string="Empleado" context="{'group_by': 'employee_id'}"/>
          <filter name="grp_date" string="Fecha" context="{'group_by': 'date'}"/>
          <filter name="grp_type" string="Tipo" context="{'group_by': 'type'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- ACTION PARA MENÚ (no usa active_id en el contexto) -->
  <record id="action_employee_ledger_balance" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="view_id" ref="view_employee_ledger_move_tree_balance"/>
    <field name="search_view_id" ref="view_employee_ledger_move_search_balance"/>
    <field name="context">{}</field>
  </record>

  <!-- ACTION ENLazada AL MODELO hr.employee (aparece en menú Acciones) -->
  <record id="action_employee_ledger_balance_binding" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="view_id" ref="view_employee_ledger_move_tree_balance"/>
    <field name="search_view_id" ref="view_employee_ledger_move_search_balance"/>
    <field name="context">{'search_default_employee_id': [active_id], 'default_employee_id': active_id}</field>
    <field name="binding_model_id" ref="hr.model_hr_employee"/>
    <field name="binding_type">action</field>
  </record>

  <!-- MENÚ bajo el root del módulo de Ledger -->
  <menuitem id="menu_hr_employee_ledger_balance"
            name="Cuenta Corriente"
            parent="hr_employee_ledger_simple18.menu_hr_employee_ledger_root"
            action="action_employee_ledger_balance"/>
</odoo>