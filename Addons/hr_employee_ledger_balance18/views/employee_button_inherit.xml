<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="hr_employee_form_inherit_balance_button" model="ir.ui.view">
    <field name="name">hr.employee.form.balance.button</field>
    <field name="model">hr.employee</field>
    <field name="inherit_id" ref="hr.hr_employee_view_form"/>
    <field name="arch" type="xml">
      <xpath expr="//form/header" position="inside">
        <button name="%(action_employee_ledger_balance)d"
                type="action"
                string="Cuenta Corriente"
                class="btn btn-secondary"
                context="{'search_default_employee_id': id}"/>
      </xpath>
    </field>
  </record>
</odoo>