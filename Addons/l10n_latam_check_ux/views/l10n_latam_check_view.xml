<odoo>
    <!-- Heredamos la vista de l10n_latam_check l10n_latam_check_view_form para agregar el botón para debitar cheques propios. -->
    <record id="l10n_latam_check_view_form" model="ir.ui.view">
        <field name="name">l10n_latam.check.form.inherited</field>
        <field name="model">l10n_latam.check</field>
        <field name="inherit_id" ref="l10n_latam_check.l10n_latam_check_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_void']" position="after">
                <field name="check_add_debit_button" invisible="1"/>
                <button name="%(action_debit_check_wizard)d"
                        string="Debit check"
                        invisible="payment_method_code != 'own_checks' or issue_state != 'handed' or not check_add_debit_button"
                        type="action"/>
            </xpath>
        </field>
    </record>

    <record model="ir.ui.view" id="view_account_own_check_tree">
        <field name="name">account.check.list</field>
        <field name="model">l10n_latam.check</field>
        <field name="priority" eval="109"/>
        <field name="inherit_id" ref="l10n_latam_check.view_account_own_check_tree" />
        <field name="arch" type="xml">
            <list position="inside">
                <header>
                    <button name="%(action_debit_check_wizard)d" type="action" string="Debit check"/>
                </header>
            </list>
            <xpath expr="//field[@name='payment_date']" position="before">
                <field name="date" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='issue_state']" position="after">
                <field name="memo" optional="hide"/>
            </xpath>
            <xpath expr="//field[@name='amount']" position="attributes">
                <attribute name="sum">Total</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_account_third_party_check_operations_tree" model="ir.ui.view">
        <field name="name">account.check.operations.list.inherit</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="l10n_latam_check.view_account_third_party_check_operations_tree"/>
        <field name="arch" type="xml">
            <field name="state" position="after">
                <field name="l10n_latam_move_check_ids_operation_date" optional="hide"/>
            </field>
        </field>
    </record>

    <record model="ir.ui.view" id="view_account_payment_search">
        <field name="name">account.check.search.inherit</field>
        <field name="model">l10n_latam.check</field>
        <field name="inherit_id" ref="l10n_latam_check.view_account_payment_search"/>
        <field name="arch" type="xml">
            <xpath expr="//filter[@name='payment_date']" position="after">
                <filter string="Last 90 days" name="last_90_days" domain="[('payment_date', '&gt;=', (context_today() - relativedelta(days=90)).strftime('%Y-%m-%d'))]" />
            </xpath>
        </field>
    </record>

    <!-- Acción: aseguramos list + form -->
    <record id="l10n_latam_check.action_third_party_check" model="ir.actions.act_window">
        <field name="view_mode">list,form</field>
        <field name="domain">[('payment_method_code', '=', 'new_third_party_checks'), ('payment_state', '!=', 'draft')]</field>
    </record>

    <!-- Listado cheques de terceros: links + botones a Origen/Destino -->
    <record id="view_account_third_party_check_tree_open_links" model="ir.ui.view">
        <field name="name">l10n_latam.check.third.party.list.open.links</field>
        <field name="model">l10n_latam.check</field>
        <field name="inherit_id" ref="l10n_latam_check.view_account_third_party_check_tree"/>
        <field name="priority" eval="120"/>
        <field name="arch" type="xml">
            <!-- importante: que no quede editable, sino el click entra en edición -->
            <xpath expr="//list" position="attributes">
                <attribute name="editable" remove="1"/>
            </xpath>

            <!-- agregamos accesos sin depender del nombre de campos existentes -->
            <xpath expr="//list" position="inside">
                <!-- Botones por fila -->
                <button name="action_open_origin_payment" type="object" string="Origen" icon="fa-arrow-left" optional="hide"/>
                <button name="action_open_dest_payment" type="object" string="Destino" icon="fa-arrow-right" optional="hide"/>
                <button name="action_open_origin_move" type="object" string="Asiento Origen" icon="fa-book" optional="hide"/>
                <button name="action_open_dest_move" type="object" string="Asiento Destino" icon="fa-book" optional="hide"/>

                <!-- Columnas clickeables (Many2one) -->
                <field name="payment_id" string="Recibo Origen" optional="hide"/>
                <field name="origin_move_id" optional="hide"/>
                <field name="last_operation_id" optional="hide"/>
                <field name="last_operation_move_id" optional="hide"/>
            </xpath>
        </field>
    </record>

</odoo>
