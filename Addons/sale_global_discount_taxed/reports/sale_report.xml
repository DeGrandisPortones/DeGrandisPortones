<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_saleorder_document_inherit_global_discount"
            inherit_id="sale.report_saleorder_document">
    <!-- Insertar filas en la tabla de totales -->
    <xpath expr="//table[contains(@class,'o_main_total')]/tbody" position="inside">

      <!-- Normalizar porcentaje a fracción -->
      <t t-set="graw" t-value="o.global_discount_rate or 0.0"/>
      <t t-set="g" t-value="graw if graw &lt;= 1.0 else (graw / 100.0)"/>

      <tr>
        <td colspan="3" class="text-end">
          <span>Subtotal (antes de descuento):</span>
        </td>
        <td class="text-end">
          <span t-esc="format_amount(o.amount_untaxed_before_global, o.currency_id)"/>
        </td>
      </tr>

      <tr>
        <td colspan="3" class="text-end">
          <span>Descuento global (<t t-esc="g * 100.0"/>%):</span>
        </td>
        <td class="text-end">
          <span t-esc="format_amount(o.global_discount_amount, o.currency_id)"/>
        </td>
      </tr>

      <tr>
        <td colspan="4"><hr/></td>
      </tr>
    </xpath>
  </template>
</odoo>
