<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar vista de Pedido de Venta (Presupuesto) -->
    <record id="view_order_form_global_discount" model="ir.ui.view">
        <field name="name">sale.order.form.global.discount</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <!-- Insertar líneas arriba del Subtotal para mostrar la resta explícita -->
            <xpath expr="//field[@name='amount_untaxed']" position="before">
                <!-- Subtotal (antes de descuento global) -->
                <label for="amount_untaxed_before_global" class="o_td_label"/>
                <div class="o_td_field">
                    <field name="amount_untaxed_before_global"
                           readonly="1"
                           options="{'currency_field': 'currency_id'}"/>
                </div>

                <!-- Descuento global -->
                <label for="global_discount_amount" class="o_td_label"/>
                <div class="o_td_field">
                    <field name="global_discount_amount"
                           readonly="1"
                           options="{'currency_field': 'currency_id'}"/>
                </div>

                <!-- Separador -->
                <div class="o_td_label oe_subtotal_footer_separator"/>
                <div class="o_td_field oe_subtotal_footer_separator"/>
            </xpath>

            <!-- % Global en el bloque de totales (alineado) -->
            <xpath expr="//field[@name='amount_tax']" position="before">
                <label for="global_discount_rate" class="o_td_label"/>
                <div class="o_td_field">
                    <field name="global_discount_rate" widget="percentage"/>
                </div>
            </xpath>

        </field>
    </record>
</odoo>
