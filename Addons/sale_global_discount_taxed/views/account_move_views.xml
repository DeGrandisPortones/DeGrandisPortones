<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_move_form_global_discount" model="ir.ui.view">
    <field name="name">account.move.form.global.discount</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <!-- Footer propio al final del sheet, con grilla de totales -->
      <xpath expr="//sheet" position="inside">
        <group name="global_discount_footer_move" class="oe_subtotal_footer">
          <!-- Subtotal (antes de descuento) -->
          <label for="amount_untaxed_before_global" class="o_td_label"/>
          <div class="o_td_field">
            <field name="amount_untaxed_before_global"
                   readonly="1"
                   options="{'currency_field': 'currency_id'}"/>
          </div>

          <!-- Descuento global (importe) -->
          <label for="global_discount_amount" class="o_td_label"/>
          <div class="o_td_field">
            <field name="global_discount_amount"
                   readonly="1"
                   options="{'currency_field': 'currency_id'}"/>
          </div>

          <!-- Separador visual -->
          <div class="o_td_label oe_subtotal_footer_separator"/>
          <div class="o_td_field oe_subtotal_footer_separator"/>

          <!-- % Descuento global (editable si querés retocar en factura) -->
          <label for="global_discount_rate" class="o_td_label"/>
          <div class="o_td_field">
            <field name="global_discount_rate" widget="percentage"/>
          </div>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
