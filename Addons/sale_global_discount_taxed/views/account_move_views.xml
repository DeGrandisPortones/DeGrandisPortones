<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_move_form_global_discount" model="ir.ui.view">
    <field name="name">account.move.form.global.discount</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

      <!-- Mostrar % en totales de la factura (editable por si se ajusta) -->
      <xpath expr="//field[@name='amount_tax']" position="before">
        <label for="global_discount_rate" class="o_td_label"/>
        <div class="o_td_field">
          <field name="global_discount_rate" widget="percentage"/>
        </div>
      </xpath>

      <!-- Mostrar referencia "antes de global" e importe de descuento -->
      <xpath expr="//field[@name='amount_untaxed']" position="before">
        <label for="amount_untaxed_before_global" class="o_td_label"/>
        <div class="o_td_field">
          <field name="amount_untaxed_before_global" readonly="1"
                 options="{'currency_field': 'currency_id'}"/>
        </div>

        <label for="global_discount_amount" class="o_td_label"/>
        <div class="o_td_field">
          <field name="global_discount_amount" readonly="1"
                 options="{'currency_field': 'currency_id'}"/>
        </div>

        <div class="o_td_label oe_subtotal_footer_separator"/>
        <div class="o_td_field oe_subtotal_footer_separator"/>
      </xpath>

    </field>
  </record>
</odoo>
