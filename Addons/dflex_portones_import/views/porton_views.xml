<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_dflex_porton_tree" model="ir.ui.view">
    <field name="name">dflex.porton.tree</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <tree string="Portones">
        <field name="name"/>
        <field name="import_id"/>
        <field name="source_row"/>
        <field name="state"/>
      </tree>
    </field>
  </record>

  <record id="view_dflex_porton_form" model="ir.ui.view">
    <field name="name">dflex.porton.form</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <field name="name"/>
            <field name="import_id"/>
            <field name="source_row"/>
            <field name="state"/>
          </group>
          <notebook>
            <page string="Especificaciones (tabla)">
              <field name="spec_ids" context="{{'default_porton_id': active_id}}">
                <tree editable="bottom">
                  <field name="key"/>
                  <field name="value"/>
                </tree>
              </field>
            </page>
            <page string="JSON">
              <field name="specs_json" widget="json"/>
            </page>
          </notebook>
        </sheet>
        <header>
          <button name="action_view_specs" type="object" string="Ver tabla" class="oe_highlight"/>
        </header>
      </form>
    </field>
  </record>

  <record id="action_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">dflex.porton</field>
    <field name="view_mode">tree,form,pivot</field>
    <field name="context">{{}}
    </field>
  </record>
</odoo>