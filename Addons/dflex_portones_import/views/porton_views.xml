
<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <record id="action_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">dflex.porton</field>
    <field name="view_mode">list,form</field>
  </record>

  <record id="view_dflex_porton_list" model="ir.ui.view">
    <field name="name">dflex.porton.list</field>
    <field name="model">x_dflex.porton</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="x_nota_de_venta"/>
        <field name="x_nombre_del_cliente"/>
        <field name="x_direccion_del_cliente"/>
        <field name="x_distribuidor"/>
      </list>
    </field>
  </record>

  <record id="view_dflex_porton_form" model="ir.ui.view">
    <field name="name">dflex.porton.form</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <field name="name"/>
          </group>
          <group string="Datos">
            <field name="x_nota_de_venta"/>
            <field name="x_nombre_del_cliente"/>
            <field name="x_direccion_del_cliente"/>
            <field name="x_distribuidor"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

</odoo>
