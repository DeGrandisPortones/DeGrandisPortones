<?xml version="1.0" encoding="UTF-8"?>
<odoo>

  <!-- Acción: usa nuestras vistas full -->
  <record id="action_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">x_dflex.porton</field>
    <field name="view_mode">list,form</field>
    <!-- En Odoo 17/18 podés fijar el orden de vistas así: -->
    <field name="view_ids" eval="[
      (0, 0, {'sequence': 1, 'view_mode': 'list', 'view_id': ref('view_x_dflex_porton_list_full')}),
      (0, 0, {'sequence': 2, 'view_mode': 'form', 'view_id': ref('view_x_dflex_porton_form_full')})
    ]"/>
  </record>

  <!-- LISTADO FULL -->
  <record id="view_x_dflex_porton_list_full" model="ir.ui.view">
    <field name="name">x_dflex.porton.list.full</field>
    <field name="model">x_dflex.porton</field>
    <field name="arch" type="xml">
      <list string="Portones" editable="bottom" create="True" edit="True" delete="True">
        <field name="x_name" string="Nombre"/>
        <field name="x_nota_de_venta"/>
        <field name="x_nombre_del_cliente"/>
        <field name="x_direccion_del_cliente"/>
        <field name="x_distribuidor"/>
        <field name="x_fecha_de_pedido"/>
        <field name="x_fecha_de_entrega"/>
        <field name="x_fecha_entrega_estimada"/>
        <field name="x_dias_restantes"/>
        <field name="x_dias_transcurridos"/>
        <field name="x_estado"/>
        <field name="x_revestimiento_fabricante"/>
        <field name="x_revestimiento_tipo"/>
        <field name="x_lucera"/>
        <field name="x_color_del_revestimiento"/>
        <field name="x_listones"/>
        <field name="x_partida"/>
        <field name="x_fecha_de_inicio_produccion"/>
        <field name="x_parantes_internos_cantidad"/>
        <field name="x_parantes_distribucion"/>
        <field name="x_color_sistema"/>
        <field name="x_puerta_condicion"/>
        <field name="x_puerta_posicion"/>
        <field name="x_puerta_descripcion"/>
        <field name="x_motor_condicion"/>
        <field name="x_motor_posicion"/>
        <field name="x_pasador"/>
        <field name="x_armado"/>
        <field name="x_instalacion"/>
        <field name="x_instalacion_empotraduras"/>
        <field name="x_empotraduras_posicion"/>
        <field name="x_parantes_cantidad"/>
        <field name="x_parantes_descripcion"/>
        <field name="x_piernas_tipo"/>
        <field name="x_piernas_altura"/>
        <field name="x_revestimiento_espesor"/>
        <field name="x_dintel_tipo"/>
        <field name="x_dintel_ancho"/>
        <field name="x_largo_brazo"/>
        <field name="x_hueco_chico"/>
        <field name="x_hueco_grande"/>
        <field name="x_rebaje"/>
        <field name="x_rebaje_descuento"/>
        <field name="x_rebaje_altura"/>
        <field name="x_rebaje_lateral_inferior"/>
        <field name="x_rebaje_lateral_inferior_descuento"/>
      </list>
    </field>
  </record>

  <!-- FORM FULL (organizado en pestañas) -->
  <record id="view_x_dflex_porton_form_full" model="ir.ui.view">
    <field name="name">x_dflex.porton.form.full</field>
    <field name="model">x_dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <field name="x_name" string="Nombre"/>
          </group>
          <notebook>
            <page string="Datos">
              <group>
                <field name="x_nota_de_venta"/>
                <field name="x_nombre_del_cliente"/>
                <field name="x_direccion_del_cliente"/>
                <field name="x_distribuidor"/>
                <field name="x_estado"/>
                <field name="x_fecha_de_pedido"/>
                <field name="x_fecha_de_entrega"/>
                <field name="x_fecha_entrega_estimada"/>
                <field name="x_dias_transcurridos"/>
                <field name="x_dias_restantes"/>
              </group>
            </page>
            <page string="Revestimiento">
              <group>
                <field name="x_revestimiento_fabricante"/>
                <field name="x_revestimiento_tipo"/>
                <field name="x_color_del_revestimiento"/>
                <field name="x_listones"/>
                <field name="x_revestimiento_espesor"/>
              </group>
            </page>
            <page string="Puerta y Motor">
              <group>
                <field name="x_puerta_condicion"/>
                <field name="x_puerta_posicion"/>
                <field name="x_puerta_descripcion"/>
                <field name="x_motor_condicion"/>
                <field name="x_motor_posicion"/>
                <field name="x_pasador"/>
                <field name="x_armado"/>
                <field name="x_instalacion"/>
              </group>
            </page>
            <page string="Parantes / Empotraduras">
              <group>
                <field name="x_parantes_internos_cantidad"/>
                <field name="x_parantes_distribucion"/>
                <field name="x_parantes_cantidad"/>
                <field name="x_parantes_descripcion"/>
                <field name="x_instalacion_empotraduras"/>
                <field name="x_empotraduras_posicion"/>
                <field name="x_piernas_tipo"/>
                <field name="x_piernas_altura"/>
              </group>
            </page>
            <page string="Medidas / Dintel">
              <group>
                <field name="x_dintel_tipo"/>
                <field name="x_dintel_ancho"/>
                <field name="x_largo_brazo"/>
                <field name="x_hueco_chico"/>
                <field name="x_hueco_grande"/>
              </group>
            </page>
            <page string="Rebajes">
              <group>
                <field name="x_rebaje"/>
                <field name="x_rebaje_descuento"/>
                <field name="x_rebaje_altura"/>
                <field name="x_rebaje_lateral_inferior"/>
                <field name="x_rebaje_lateral_inferior_descuento"/>
              </group>
            </page>
            <page string="Producción">
              <group>
                <field name="x_partida"/>
                <field name="x_fecha_de_inicio_produccion"/>
              </group>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

</odoo>
