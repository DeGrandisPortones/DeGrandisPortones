<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_dflex_porton_list" model="ir.ui.view">
    <field name="name">dflex.porton.list</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <list string="Portones">
        <field name="name"/>
        <field name="import_id"/>
        <field name="source_row"/>
      </list>
    </field>
  </record>

  <record id="view_dflex_porton_form_base" model="ir.ui.view">
    <field name="name">dflex.porton.form.base</field>
    <field name="model">dflex.porton</field>
    <field name="arch" type="xml">
      <form string="Portón">
        <sheet>
          <group>
            <field name="name"/>
            <field name="import_id"/>
            <field name="source_row"/>
          </group>
          <notebook>
            <page string="Datos importados">
              <group>
                <label string="(La vista dinámica aún no fue generada)"/>
              </group>
            </page>
            <page string="JSON">
              <field name="specs_json" widget="json"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_dflex_porton" model="ir.actions.act_window">
    <field name="name">Portones</field>
    <field name="res_model">dflex.porton</field>
    <field name="view_mode">list,form</field>
    <field name="context">{}</field>
  </record>
</odoo>