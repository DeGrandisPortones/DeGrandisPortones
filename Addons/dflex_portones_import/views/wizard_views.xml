<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_dflex_porton_import_wizard" model="ir.ui.view">
    <field name="name">dflex.porton.import.wizard.form</field>
    <field name="model">dflex.porton.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importar Portones (CSV)">
        <sheet>
          <group>
            <field name="file" filename="filename"/>
            <field name="filename" readonly="1"/>
            <label class="o_form_label" for="file" string="Formato: CSV con 1 única fila de encabezados; datos desde la fila 2. Separador ',' o ';'."/>
          </group>
          <footer>
            <button name="action_import" type="object" class="btn-primary" string="Importar"/>
            <button special="cancel" string="Cancelar"/>
          </footer>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Acción para abrir el wizard (sin depender de x_dflex.porton) -->
  <record id="action_dflex_porton_import" model="ir.actions.act_window">
    <field name="name">Importar Portones</field>
    <field name="res_model">dflex.porton.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="view_id" ref="view_dflex_porton_import_wizard"/>
  </record>
</odoo>
