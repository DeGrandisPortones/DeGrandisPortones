<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_porton_import_wizard_form" model="ir.ui.view">
    <field name="name">x_dflex.porton.import.wizard.form</field>
    <field name="model">x_dflex.porton.import.wizard</field>
    <field name="arch" type="xml">
      <form string="Importar Portones">
        <group>
          <field name="file" filename="filename"/>
          <field name="filename" readonly="1"/>
          <field name="update_if_exists"/>
          <field name="delimiter"/>
          <field name="encoding"/>
        </group>
        <footer>
          <button name="action_import" type="object" class="btn-primary" string="Importar"/>
          <button special="cancel" string="Cancelar" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_porton_import_wizard" model="ir.actions.act_window">
    <field name="name">Importar Portones</field>
    <field name="res_model">x_dflex.porton.import.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">current</field>
  </record>
</odoo>
