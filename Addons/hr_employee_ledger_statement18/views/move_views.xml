<odoo>
  <!-- LISTA para ver el estado de cuenta -->
  <record id="view_employee_ledger_move_tree_statement" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list.statement</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list string="Cuenta Corriente">
        <field name="date"/>
        <field name="employee_id"/>
        <field name="type"/>
        <field name="concept"/>
        <field name="amount"/>
        <!-- Campos opcionales si existen en tu modelo extendido -->
        <field name="debit" optional="show"/>
        <field name="credit" optional="show"/>
        <field name="running_balance" string="Saldo" optional="show" readonly="1"/>
      </list>
    </field>
  </record>

  <!-- SEARCH de la lista -->
  <record id="view_employee_ledger_move_search_statement" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.search.statement</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <search string="Buscar movimientos">
        <field name="employee_id"/>
        <filter name="this_month" string="Este mes"
                domain="[('date','&gt;=', context_today().replace(day=1))]"/>
        <filter name="charges" string="Cargos" domain="[('type','=','charge')]"/>
        <filter name="payments" string="Abonos" domain="[('type','=','payment')]"/>
        <group expand="0" string="Agrupar por">
          <filter string="Empleado" context="{'group_by':'employee_id'}"/>
          <filter string="Tipo" context="{'group_by':'type'}"/>
          <filter string="Fecha" context="{'group_by':'date'}"/>
        </group>
      </search>
    </field>
  </record>

  <!-- Acción (usada por el wizard) -->
  <record id="action_employee_ledger_statement_result" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="view_id" ref="view_employee_ledger_move_tree_statement"/>
    <field name="search_view_id" ref="view_employee_ledger_move_search_statement"/>
  </record>
</odoo>
