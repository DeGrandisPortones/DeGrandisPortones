<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_employee_ledger_move_tree_statement" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.list.statement</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <list create="false" editable="bottom">
        <field name="date"/>
        <field name="employee_id"/>
        <field name="type"/>
        <field name="concept"/>
        <field name="amount"/>
      </list>
    </field>
  </record>

  <record id="view_employee_ledger_move_search_statement" model="ir.ui.view">
    <field name="name">hr.employee.ledger.move.search.statement</field>
    <field name="model">hr.employee.ledger.move</field>
    <field name="arch" type="xml">
      <search>
        <field name="employee_id"/>
        <field name="date"/>
        <field name="type"/>
        <field name="concept"/>
        <group expand="0" string="Agrupar por">
          <filter name="grp_employee" string="Empleado" context="{'group_by':'employee_id'}"/>
          <filter name="grp_date" string="Fecha" context="{'group_by':'date'}"/>
          <filter name="grp_type" string="Tipo" context="{'group_by':'type'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="action_employee_ledger_moves_statement" model="ir.actions.act_window">
    <field name="name">Movimientos</field>
    <field name="type">ir.actions.act_window</field>
    <field name="res_model">hr.employee.ledger.move</field>
    <field name="view_mode">list,form</field>
    <field name="search_view_id" ref="view_employee_ledger_move_search_statement"/>
    <field name="context">{}</field>
    <field name="domain">[]</field>
  </record>
</odoo>
