
<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <record id="view_hr_employee_ledger_statement_wizard" model="ir.ui.view">
    <field name="name">hr.employee.ledger.statement.wizard.form</field>
    <field name="model">hr.employee.ledger.statement.wizard</field>
    <field name="arch" type="xml">
      <form string="Cuenta Corriente">
        <group>
          <field name="employee_id" options="{'no_create': True}"/>
          <field name="date_from"/>
          <field name="date_to"/>
        </group>
        <footer>
          <button name="action_open_statement" type="object" string="Ver movimientos" class="btn-primary"/>
          <button string="Cancelar" special="cancel"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_hr_employee_ledger_statement_wizard" model="ir.actions.act_window">
    <field name="name">Cuenta Corriente</field>
    <field name="res_model">hr.employee.ledger.statement.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="view_id" ref="view_hr_employee_ledger_statement_wizard"/>
  </record>
</odoo>
