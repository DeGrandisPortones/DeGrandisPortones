<odoo>
  <record id="view_employee_ledger_statement_wizard_form" model="ir.ui.view">
    <field name="name">hr.employee.ledger.statement.wizard.form</field>
    <field name="model">hr.employee.ledger.statement.wizard</field>
    <field name="arch" type="xml">
      <form string="Cuenta Corriente del Empleado">
        <group>
          <field name="employee_id" required="1" domain="[('active','=',True)]"/>
          <field name="date_from"/>
          <field name="date_to"/>
        </group>
        <footer>
          <button name="action_open_statement" type="object" string="Ver movimientos" class="btn-primary"/>
          <button string="Cancelar" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>
</odoo>