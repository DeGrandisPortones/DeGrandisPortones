<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  <!-- Extensión de Pagos: vínculo con Cheques (en cartera) + estados -->

  <record id="view_account_payment_form_dflex_checks" model="ir.ui.view">
    <field name="name">account.payment.form.dflex.checks</field>
    <field name="model">account.payment</field>
    <field name="inherit_id" ref="account.view_account_payment_form"/>
    <field name="arch" type="xml">

      <!-- Tablero para seleccionar cheques en el detalle (no en el encabezado) -->
      <xpath expr="//notebook" position="inside">
        <page string="Cheques en cartera" name="dflex_checks">
          <field name="dflex_check_line_ids" nolabel="1">
            <list editable="bottom">
              <field name="check_id" options="{'no_create': True}"/>
              <field name="check_state" readonly="1"/>
              <field name="bank_id" readonly="1"/>
              <field name="type" readonly="1"/>
              <field name="issue_date" readonly="1"/>
              <field name="amount" readonly="1"/>
              <field name="partner_id" readonly="1"/>
            </list>
          </field>
        </page>
      </xpath>

      <!-- Acción para marcar devuelto por rechazo -->
      <xpath expr="//header" position="inside">
        <button name="action_dflex_mark_check_returned"
                type="object"
                string="Marcar cheque devuelto"
                class="oe_highlight"
                invisible="state != 'posted' or not dflex_has_delivered_checks"/>
      </xpath>

    </field>
  </record>

  <record id="view_account_payment_list_dflex_checks" model="ir.ui.view">
    <field name="name">account.payment.list.dflex.checks</field>
    <field name="model">account.payment</field>
    <field name="inherit_id" ref="account.view_account_payment_tree"/>
    <field name="arch" type="xml">
      <xpath expr="(//tree|//list)[1]" position="inside">
        <field name="dflex_check_id" optional="show"/>
        <field name="dflex_check_state" optional="show"/>
      </xpath>
    </field>
  </record>

</odoo>
