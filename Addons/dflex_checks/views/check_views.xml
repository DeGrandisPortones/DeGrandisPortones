<?xml version="1.0" encoding="UTF-8"?>
<odoo>
  
  <!-- Server actions (evitan validación estricta de botones type="object" en algunas builds) -->
  <record id="action_dflex_checkbook_generate_checks" model="ir.actions.server">
    <field name="name">Generar cheques</field>
    <field name="model_id" ref="model_dflex_checkbook"/>
    <field name="state">code</field>
    <field name="code">records.action_generate_checks()</field>
  </record>

  <record id="action_dflex_checkbook_close" model="ir.actions.server">
    <field name="name">Cerrar chequera</field>
    <field name="model_id" ref="model_dflex_checkbook"/>
    <field name="state">code</field>
    <field name="code">records.action_close()</field>
  </record>

<!-- Menú raíz (temporalmente en Administración para evitar conflictos) -->
  <menuitem id="menu_dflex_checks_root"
            name="Cheques Propios"
            parent="accountant.menu_accounting"
            sequence="90"/>

  <!-- Acción y vistas de Chequeras -->
  <record id="action_dflex_checkbook" model="ir.actions.act_window">
    <field name="name">Chequeras</field>
    <field name="res_model">dflex.checkbook</field>
    <field name="view_mode">list,form</field>
    <field name="context">{}</field>
  </record>

  <menuitem id="menu_dflex_checkbook"
            name="Chequeras"
            parent="menu_dflex_checks_root"
            action="action_dflex_checkbook"
            sequence="10"/>

  <record id="view_dflex_checkbook_list" model="ir.ui.view">
    <field name="name">dflex.checkbook.list</field>
    <field name="model">dflex.checkbook</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="bank_id" domain="[('id', 'in', available_bank_ids)]"/>
            <field name="available_bank_ids" invisible="1"/>
        <field name="type"/>
        <field name="start_number"/>
        <field name="quantity"/>
        <field name="last_number"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="view_dflex_checkbook_form" model="ir.ui.view">
    <field name="name">dflex.checkbook.form</field>
    <field name="model">dflex.checkbook</field>
    <field name="arch" type="xml">
      <form string="Chequera">
        <sheet>
          <group>
            <field name="name"/>
            <field name="bank_id"/>
            <field name="type"/>
            <field name="start_number"/>
            <field name="quantity"/>
            <field name="last_number" readonly="1"/>
            <field name="state" readonly="1"/>
          </group>
          <group>
            <!-- Odoo 17/18: usar 'invisible' en lugar de attrs/states -->
            <button name="%(dflex_checks.action_dflex_checkbook_generate_checks)d" type="action"
                    string="Generar cheques"
                    class="oe_highlight"
                    invisible="state != 'draft'"/>
            <button name="%(dflex_checks.action_dflex_checkbook_close)d" type="action"
                    string="Cerrar chequera"
                    invisible="state != 'generated'"/>
          </group>
          <notebook>
            <page string="Cheques">
              <field name="check_ids" context="{'default_bank_id': bank_id, 'default_type': type}">
                <list editable="bottom">
                  <field name="name"/>
                  <field name="number"/>
                  <field name="type"/>
                  <field name="bank_id"/>
                  <field name="issue_date"/>
                  <field name="payment_date"/>
                  <field name="amount"/>
                  <field name="partner_id"/>
                  <field name="state"/>
                </list>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Acción y vistas de Cheques -->
  <record id="action_dflex_check" model="ir.actions.act_window">
    <field name="name">Cheques</field>
    <field name="res_model">dflex.check</field>
    <field name="view_mode">list,form</field>
    <field name="context">{}</field>
  </record>

  <menuitem id="menu_dflex_check"
            name="Cheques"
            parent="menu_dflex_checks_root"
            action="action_dflex_check"
            sequence="20"/>

  <record id="view_dflex_check_list" model="ir.ui.view">
    <field name="name">dflex.check.list</field>
    <field name="model">dflex.check</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="issue_date"/>
        <field name="payment_date"/>
        <field name="amount"/>
        <field name="bank_id"/>
        <field name="cuit_proveedor"/>
        <field name="partner_name"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="view_dflex_check_form" model="ir.ui.view">
    <field name="name">dflex.check.form</field>
    <field name="model">dflex.check</field>
    <field name="arch" type="xml">
      <form string="Cheque Propio">
        <header>
          <!-- Reemplazo de attrs/states por 'invisible' -->
          <button name="action_reset_available" type="object" string="Volver a disponible"
                  invisible="state in ['available','debited']"/>
          <button name="action_deliver" type="object" string="Entregar" class="oe_highlight"
                  invisible="state != 'available'"/>
          <button name="action_debit" type="object" string="Debitar" class="oe_highlight"
                  invisible="state != 'delivered'"/>
          <button name="action_return" type="object" string="Marcar devuelto"
                  invisible="state != 'delivered'"/>
          <button name="action_cancel" type="object" string="Anular"
                  invisible="state == 'debited'"/>
          <field name="state" widget="statusbar"
                 statusbar_visible="available,delivered,returned,debited,cancelled"/>
        </header>
        <sheet>
          <group>
            <field name="checkbook_id"/>
            <field name="name"/>
            <field name="number"/>
            <field name="type"/>
            <field name="bank_id" domain="[('id', 'in', available_bank_ids)]"/>
            <field name="available_bank_ids" invisible="1"/>
          </group>
          <group>
            <field name="issue_date"/>
            <field name="payment_date"/>
            <field name="amount"/>
            <field name="currency_id"/>
          </group>
          <group string="Proveedor">
            <field name="partner_id"/>
            <field name="cuit_proveedor" readonly="1"/>
            <field name="partner_name" readonly="1"/>
          </group>
          <group>
            <field name="move_id" readonly="1"/>
            <field name="payment_id" readonly="1"/>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_dflex_check_search" model="ir.ui.view">
    <field name="name">dflex.check.search</field>
    <field name="model">dflex.check</field>
    <field name="arch" type="xml">
      <search string="Buscar Cheques">
        <field name="name"/>
        <field name="partner_id"/>
        <field name="bank_id"/>
        <filter name="available" string="Disponibles" domain="[('state','=','available')]"/>
        <filter name="delivered" string="Entregados" domain="[('state','=','delivered')]"/>
        <filter name="returned" string="Devueltos" domain="[('state','=','returned')]"/>
        <filter name="debited" string="Debitados" domain="[('state','=','debited')]"/>
        <filter name="cancelled" string="Anulados" domain="[('state','=','cancelled')]"/>
        <group expand="0" string="Agrupar por">
          <filter name="group_bank" string="Banco" context="{'group_by':'bank_id'}"/>
          <filter name="group_state" string="Estado" context="{'group_by':'state'}"/>
          <filter name="group_book" string="Chequera" context="{'group_by':'checkbook_id'}"/>
        </group>
      </search>
    </field>
  </record>
</odoo>
